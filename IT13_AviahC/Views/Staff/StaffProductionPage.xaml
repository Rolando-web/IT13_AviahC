<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:IT13_AviahC.Views.Staff.Components"
             xmlns:adminComp="clr-namespace:IT13_AviahC.Views.Admin.Components"
             x:Class="IT13_AviahC.Views.Staff.StaffProductionPage"
             BackgroundColor="#F3F0FA">
    <Grid ColumnDefinitions="Auto,*">
        <!-- Sidebar -->
        <components:StaffSidebarView Grid.Column="0" CurrentPage="StaffProduction" />

        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <!-- Header -->
            <adminComp:AdminHeaderView Grid.Row="0" />

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="32" Spacing="24">
                    <!-- Title Row -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label Text="Production Output" FontSize="28" FontAttributes="Bold" TextColor="#463366" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="+ New Production Batch" BackgroundColor="#624890" TextColor="White" CornerRadius="12" Padding="24,0" FontAttributes="Bold" FontSize="14" HeightRequest="44" />
                    </Grid>

                    <!-- Main Content Grid -->
                    <Grid ColumnDefinitions="2*,*" ColumnSpacing="24">
                        <!-- Left Column: Active Batches -->
                        <VerticalStackLayout Grid.Column="0" Spacing="16">
                            <Label Text="Active &amp; Recent Batches" FontSize="18" FontAttributes="Bold" TextColor="#463366" Margin="0,0,0,8" />
                            
                            <!-- Batch 402 -->
                            <Border BackgroundColor="White" StrokeShape="RoundRectangle 20" Padding="24" StrokeThickness="0">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="20">
                                    <Border BackgroundColor="#F3F0FA" StrokeShape="RoundRectangle 12" HeightRequest="48" WidthRequest="48" StrokeThickness="0">
                                        <Path Data="M19.66,3L12,10.66L4.34,3L3,4.34L10.66,12L3,19.66L4.34,21L12,13.34L19.66,21L21,19.66L13.34,12L21,4.34L19.66,3Z"
                                              Fill="#624890" Aspect="Uniform" HeightRequest="18" WidthRequest="18" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="Violet Summer Dress" FontAttributes="Bold" FontSize="16" TextColor="#1E293B" />
                                            <Border BackgroundColor="#F1F5F9" StrokeShape="RoundRectangle 8" Padding="8,2" StrokeThickness="0">
                                                <Label Text="BATCH-402" FontSize="10" TextColor="#64748B" FontAttributes="Bold" />
                                            </Border>
                                        </HorizontalStackLayout>
                                        <Label Text="🕒 Started 2 days ago" FontSize="13" TextColor="#64748B" />
                                        <Label Text="Target Quantity: 50 pcs" FontSize="13" TextColor="#64748B" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="2" Spacing="8" HorizontalOptions="End">
                                        <HorizontalStackLayout Spacing="4" HorizontalOptions="End">
                                            <Label Text="Progress" FontSize="12" TextColor="#64748B" />
                                            <Label Text="60%" FontAttributes="Bold" FontSize="12" TextColor="#1E293B" />
                                        </HorizontalStackLayout>
                                        <ProgressBar Progress="0.6" ProgressColor="#9333EA" WidthRequest="120" />
                                        <Button Text="Update Progress" BackgroundColor="White" TextColor="#624890" BorderColor="#624890" BorderWidth="1" CornerRadius="8" FontSize="12" HeightRequest="32" Padding="12,0" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>

                            <!-- Batch 401 -->
                            <Border BackgroundColor="White" StrokeShape="RoundRectangle 20" Padding="24" StrokeThickness="0">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="20">
                                    <Border BackgroundColor="#DCFCE7" StrokeShape="RoundRectangle 12" HeightRequest="48" WidthRequest="48" StrokeThickness="0">
                                        <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10s10-4.48,10-10S17.52,2,12,2z M10,17l-5-5l1.41-1.41L10,14.17l7.59-7.59L19,8 L10,17z"
                                              Fill="#16A34A" Aspect="Uniform" HeightRequest="18" WidthRequest="18" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="Lavender Blouse" FontAttributes="Bold" FontSize="16" TextColor="#1E293B" />
                                            <Border BackgroundColor="#F1F5F9" StrokeShape="RoundRectangle 8" Padding="8,2" StrokeThickness="0">
                                                <Label Text="BATCH-401" FontSize="10" TextColor="#64748B" FontAttributes="Bold" />
                                            </Border>
                                        </HorizontalStackLayout>
                                        <Label Text="🕒 Completed yesterday" FontSize="13" TextColor="#64748B" />
                                        <Label Text="Target Quantity: 30 pcs" FontSize="13" TextColor="#64748B" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="2" Spacing="8" HorizontalOptions="End" VerticalOptions="Center">
                                        <HorizontalStackLayout Spacing="4" HorizontalOptions="End">
                                            <Label Text="Progress" FontSize="12" TextColor="#64748B" />
                                            <Label Text="100%" FontAttributes="Bold" FontSize="12" TextColor="#16A34A" />
                                        </HorizontalStackLayout>
                                        <ProgressBar Progress="1.0" ProgressColor="#16A34A" WidthRequest="120" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>

                            <!-- Batch 400 -->
                            <Border BackgroundColor="White" StrokeShape="RoundRectangle 20" Padding="24" StrokeThickness="0">
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="20">
                                    <Border BackgroundColor="#F3F0FA" StrokeShape="RoundRectangle 12" HeightRequest="48" WidthRequest="48" StrokeThickness="0">
                                        <Path Data="M19.66,3L12,10.66L4.34,3L3,4.34L10.66,12L3,19.66L4.34,21L12,13.34L19.66,21L21,19.66L13.34,12L21,4.34L19.66,3Z"
                                              Fill="#624890" Aspect="Uniform" HeightRequest="18" WidthRequest="18" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout Grid.Column="1" Spacing="4">
                                        <HorizontalStackLayout Spacing="8">
                                            <Label Text="Plum Formal Trousers" FontAttributes="Bold" FontSize="16" TextColor="#1E293B" />
                                            <Border BackgroundColor="#F1F5F9" StrokeShape="RoundRectangle 8" Padding="8,2" StrokeThickness="0">
                                                <Label Text="BATCH-400" FontSize="10" TextColor="#64748B" FontAttributes="Bold" />
                                            </Border>
                                        </HorizontalStackLayout>
                                        <Label Text="🕒 Waiting for Admin" FontSize="13" TextColor="#64748B" />
                                        <Label Text="Target Quantity: 100 pcs" FontSize="13" TextColor="#64748B" />
                                    </VerticalStackLayout>
                                    <VerticalStackLayout Grid.Column="2" Spacing="8" HorizontalOptions="End" VerticalOptions="Center">
                                        <HorizontalStackLayout Spacing="4" HorizontalOptions="End">
                                            <Label Text="Progress" FontSize="12" TextColor="#64748B" />
                                            <Label Text="100%" FontAttributes="Bold" FontSize="12" TextColor="#16A34A" />
                                        </HorizontalStackLayout>
                                        <ProgressBar Progress="1.0" ProgressColor="#16A34A" WidthRequest="120" />
                                        <HorizontalStackLayout Spacing="4" HorizontalOptions="End">
                                            <Path Data="M12,17c1.1,0,2-0.9,2-2s-0.9-2-2-2s-2,0.9-2,2S10.9,17,12,17z M18,8h-1V6c0-2.76-2.24-5-5-5S7,3.24,7,6v2H6c-1.1,0-2,0.9-2,2v10 c0,1.1,0.9,2,2,2h12c1.1,0,2-0.9,2-2V10C20,8.9,19.1,8,18,8z M8.9,6c0-1.71,1.39-3.1,3.1-3.1s3.1,1.39,3.1,3.1v2H8.9V6z M18,20H6V10 h12V20z"
                                                  Fill="#94A3B8" Aspect="Uniform" HeightRequest="12" WidthRequest="12" VerticalOptions="Center" />
                                            <Label Text="Awaiting Admin Approval" FontSize="11" TextColor="#94A3B8" FontAttributes="Italic" VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Right Column: Daily Output Form -->
                        <Border Grid.Column="1" BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="32" StrokeThickness="0" VerticalOptions="Start">
                            <VerticalStackLayout Spacing="24">
                                <Label Text="Record Daily Output" FontSize="20" FontAttributes="Bold" TextColor="#1E293B" />
                                
                                <VerticalStackLayout Spacing="8">
                                    <Label Text="Batch ID" FontSize="13" TextColor="#64748B" FontAttributes="Bold" />
                                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#E2E8F0" Padding="12,0">
                                        <Picker Title="Select Active Batch" TextColor="#1E293B" FontSize="14" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="8">
                                    <Label Text="Quantity Produced Today" FontSize="13" TextColor="#64748B" FontAttributes="Bold" />
                                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#E2E8F0" Padding="12,0">
                                        <Entry Placeholder="0" Keyboard="Numeric" TextColor="#1E293B" BackgroundColor="Transparent" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="8">
                                    <Label Text="Defects / Rejects" FontSize="13" TextColor="#64748B" FontAttributes="Bold" />
                                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#E2E8F0" Padding="12,0">
                                        <Entry Placeholder="0" Keyboard="Numeric" TextColor="#1E293B" BackgroundColor="Transparent" />
                                    </Border>
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="8">
                                    <Label Text="Staff Assigned" FontSize="13" TextColor="#64748B" FontAttributes="Bold" />
                                    <Border StrokeShape="RoundRectangle 12" StrokeThickness="1" Stroke="#E2E8F0" Padding="12,0">
                                        <Picker Title="Select Staff" TextColor="#1E293B" FontSize="14" />
                                    </Border>
                                </VerticalStackLayout>

                                <Button Text="Save Output Record" BackgroundColor="#624890" TextColor="White" CornerRadius="12" HeightRequest="48" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>
