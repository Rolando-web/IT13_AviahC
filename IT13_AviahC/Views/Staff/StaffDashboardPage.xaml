<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:IT13_AviahC.Views.Staff.Components"
             xmlns:adminComp="clr-namespace:IT13_AviahC.Views.Admin.Components"
             x:Class="IT13_AviahC.Views.Staff.StaffDashboardPage"
             BackgroundColor="#F3F0FA">
    <Grid ColumnDefinitions="Auto,*">
        <!-- Sidebar -->
        <components:StaffSidebarView Grid.Column="0" CurrentPage="StaffDashboard" />

        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <!-- Header -->
            <adminComp:AdminHeaderView Grid.Row="0" />

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="32" Spacing="32">
                    <!-- Welcome Row -->
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Welcome back, Staff!" FontSize="32" FontAttributes="Bold" TextColor="#463366" />
                            <Label Text="Daily Operations &amp; Task Management" FontSize="14" TextColor="#64748B" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1" BackgroundColor="#FEF3C7" StrokeShape="RoundRectangle 12" Padding="12,6" StrokeThickness="0">
                            <HorizontalStackLayout Spacing="6">
                                <Ellipse Fill="#D97706" HeightRequest="8" WidthRequest="8" VerticalOptions="Center" />
                                <Label Text="Premium Tier" TextColor="#B45309" FontSize="11" FontAttributes="Bold" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Stats Overview -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="24">
                        <Border BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="24" StrokeThickness="0">
                            <HorizontalStackLayout Spacing="20">
                                <Border BackgroundColor="#EFF6FF" StrokeShape="RoundRectangle 12" HeightRequest="56" WidthRequest="56" StrokeThickness="0">
                                    <Path Data="M19,3H5C3.89,3,3,3.9,3,5v14c0,1.1,0.89,2,2,2h14c1.1,0,2-0.9,2-2V5C21,3.9,20.11,3,19,3z M19,19H5V5h14V19z M17,17H7v-2h10V17z M17,13H7v-2h10V13z M17,9H7V7h10V9z"
                                          Fill="#3B82F6" Aspect="Uniform" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout VerticalOptions="Center">
                                    <Label Text="12" FontSize="28" FontAttributes="Bold" TextColor="#1E293B" />
                                    <Label Text="My Tasks Today" FontSize="13" TextColor="#64748B" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>

                        <Border Grid.Column="1" BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="24" StrokeThickness="0">
                            <HorizontalStackLayout Spacing="20">
                                <Border BackgroundColor="#F0FDF4" StrokeShape="RoundRectangle 12" HeightRequest="56" WidthRequest="56" StrokeThickness="0">
                                    <Path Data="M20,6h-4V4c0-1.11-0.89-2-2-2h-4C8.89,2,8,2.89,8,4v2H4C2.89,6,2,6.89,2,8v12c0,1.11,0.89,2,2,2h16c1.11,0,2-0.89,2-2V8 C22,6.89,21.11,6,20,6z M10,4h4v2h-4V4z M20,20H4V8h16V20z M12,12c1.1,0,2,0.9,2,2s-0.9,2-2,2s-2-0.9-2-2S10.9,12,12,12z"
                                          Fill="#22C55E" Aspect="Uniform" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout VerticalOptions="Center">
                                    <Label Text="₱4,250" FontSize="28" FontAttributes="Bold" TextColor="#1E293B" />
                                    <Label Text="My Sales Today" FontSize="13" TextColor="#64748B" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>

                        <Border Grid.Column="2" BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="24" StrokeThickness="0">
                            <HorizontalStackLayout Spacing="20">
                                <Border BackgroundColor="#F5F3FF" StrokeShape="RoundRectangle 12" HeightRequest="56" WidthRequest="56" StrokeThickness="0">
                                    <Path Data="M11.99,2C6.47,2,2,6.48,2,12s4.47,10,9.99,10C17.52,22,22,17.52,22,12S17.52,2,11.99,2z M12,20c-4.42,0-8-3.58-8-8 s3.58-8,8-8s8,3.58,8,8S16.42,20,12,20z M12.5,7H11v6l5.25,3.15l0.75-1.23L12.5,12.5V7z"
                                          Fill="#8B5CF6" Aspect="Uniform" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout VerticalOptions="Center">
                                    <Label Text="85%" FontSize="28" FontAttributes="Bold" TextColor="#1E293B" />
                                    <Label Text="Completion Rate" FontSize="13" TextColor="#64748B" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Main Grid for Checklist and Actions -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="24">
                        <!-- Left Column: Operational Checklist -->
                        <Border Grid.Column="0" BackgroundColor="White" StrokeShape="RoundRectangle 28" Padding="32" StrokeThickness="0">
                            <VerticalStackLayout Spacing="24">
                                <Label Text="Operational Checklist" FontSize="22" FontAttributes="Bold" TextColor="#1E293B" />
                                <VerticalStackLayout Spacing="16">
                                    <HorizontalStackLayout Spacing="12">
                                        <CheckBox IsChecked="True" Color="#624890" />
                                        <Label Text="Restock front display" TextColor="#64748B" VerticalOptions="Center" FontSize="15" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="12">
                                        <CheckBox IsChecked="True" Color="#624890" />
                                        <Label Text="Process pending online orders" TextColor="#64748B" VerticalOptions="Center" FontSize="15" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="12">
                                        <CheckBox IsChecked="False" Color="#624890" />
                                        <Label Text="Update inventory for new shipment" TextColor="#1E293B" VerticalOptions="Center" FontSize="15" />
                                    </HorizontalStackLayout>
                                    <HorizontalStackLayout Spacing="12">
                                        <CheckBox IsChecked="False" Color="#624890" />
                                        <Label Text="Coordinate with production" TextColor="#1E293B" VerticalOptions="Center" FontSize="15" />
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Right Column: Quick Actions & Today's Goals -->
                        <VerticalStackLayout Grid.Column="1" Spacing="24">
                            <!-- Quick Actions (Purple Card) -->
                            <Border BackgroundColor="#624890" StrokeShape="RoundRectangle 24" Padding="28" StrokeThickness="0">
                                <VerticalStackLayout Spacing="20">
                                    <HorizontalStackLayout Spacing="10">
                                        <Path Data="M13,3H6C4.89,3,4,3.9,4,5v14c0,1.1,0.89,2,2,2h12c1.1,0,2-0.9,2-2V9L13,3z M12,14c-1.66,0-3-1.34-3-3s1.34-3,3-3s3,1.34,3,3 S13.66,14,12,14z"
                                              Fill="White" Aspect="Uniform" HeightRequest="16" WidthRequest="16" VerticalOptions="Center" />
                                        <Label Text="Quick Actions" TextColor="White" FontAttributes="Bold" FontSize="18" />
                                    </HorizontalStackLayout>
                                    
                                    <VerticalStackLayout Spacing="10">
                                        <Border BackgroundColor="#1AFFFFFF" StrokeShape="RoundRectangle 12" Padding="16,12" StrokeThickness="0">
                                            <HorizontalStackLayout Spacing="12">
                                                <Label Text="Record New Sale" TextColor="White" FontSize="14" VerticalOptions="Center" />
                                                <Label Text="→" TextColor="White" FontSize="16" HorizontalOptions="End" VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </Border>
                                        <Border BackgroundColor="#1AFFFFFF" StrokeShape="RoundRectangle 12" Padding="16,12" StrokeThickness="0">
                                            <HorizontalStackLayout Spacing="12">
                                                <Label Text="Receive Inventory" TextColor="White" FontSize="14" VerticalOptions="Center" />
                                                <Label Text="→" TextColor="White" FontSize="16" HorizontalOptions="End" VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                        </Border>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>

                            <!-- Today's Goals -->
                            <Border BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="28" StrokeThickness="0">
                                <VerticalStackLayout Spacing="20">
                                    <Label Text="Today's Goals" FontSize="18" FontAttributes="Bold" TextColor="#1E293B" />
                                    
                                    <VerticalStackLayout Spacing="12">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <Label Text="Sales Target" FontSize="13" TextColor="#64748B" />
                                            <Label Grid.Column="1" Text="₱4,250 / ₱6,000" FontSize="12" FontAttributes="Bold" TextColor="#1E293B" />
                                        </Grid>
                                        <ProgressBar Progress="0.7" ProgressColor="#624890" HeightRequest="8" />
                                        
                                        <Grid ColumnDefinitions="*,Auto" Margin="0,8,0,0">
                                            <Label Text="Order Processing" FontSize="13" TextColor="#64748B" />
                                            <Label Grid.Column="1" Text="12 / 15" FontSize="12" FontAttributes="Bold" TextColor="#1E293B" />
                                        </Grid>
                                        <ProgressBar Progress="0.8" ProgressColor="#22C55E" HeightRequest="8" />
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>
