<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:IT13_AviahC.Views.Supplier.Components"
             xmlns:adminComp="clr-namespace:IT13_AviahC.Views.Admin.Components"
             x:Class="IT13_AviahC.Views.Supplier.SupplierInventoryPage"
             BackgroundColor="#F3F0FA">
    <Grid ColumnDefinitions="Auto,*">
        <!-- Sidebar -->
        <components:SupplierSidebarView Grid.Column="0" CurrentPage="SupplierInventory" />

        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <!-- Header -->
            <adminComp:AdminHeaderView Grid.Row="0" />

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="32" Spacing="24">
                    <Label Text="Inventory Management" FontSize="24" FontAttributes="Bold" TextColor="#463366" />

                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                        <VerticalStackLayout>
                            <!-- Tab Header -->
                            <Border StrokeThickness="0" StrokeShape="RoundRectangle 12,12,0,0">
                                <Grid>
                                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="8" Padding="0,16">
                                        <Path Data="M21,16.5c0,0.38-0.21,0.71-0.53,0.88l-7.9,4.44C12.4,21.93,12.2,22,12,22s-0.4-0.07-0.57-0.18l-7.9-4.44 C3.21,17.21,3,16.88,3,16.5v-9c0-0.38,0.21-0.71,0.53-0.88l7.9-4.44C11.6,2.07,11.8,2,12,2s0.4,0.07,0.57,0.18l7.9,4.44 C20.79,6.79,21,7.12,21,7.5V16.5z M12,4.15L6.04,7.5L12,10.85l5.96-3.35L12,4.15z" 
                                              Fill="#463366" Aspect="Uniform" HeightRequest="16" WidthRequest="16" VerticalOptions="Center" />
                                        <Label Text="Warehouse (Raw Materials)" TextColor="#463366" FontAttributes="Bold" VerticalOptions="Center" />
                                    </HorizontalStackLayout>
                                    <BoxView HeightRequest="2" Color="#463366" VerticalOptions="End" />
                                    <BoxView HeightRequest="1" Color="#E2E8F0" VerticalOptions="End" Margin="0,0,0,-1" ZIndex="-1"/>
                                </Grid>
                            </Border>

                            <VerticalStackLayout Padding="32" Spacing="24">
                                <!-- Search and Action -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <Border StrokeShape="RoundRectangle 24" BackgroundColor="#F8FAFC" StrokeThickness="0" HeightRequest="48">
                                        <HorizontalStackLayout Padding="16,0" Spacing="12">
                                            <Path Data="M15.5 14h-.79l-.28-.27C15.41 12.59 16 11.11 16 9.5 16 5.91 13.09 3 9.5 3S3 5.91 3 9.5 5.91 16 9.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z" 
                                                  Fill="#94A3B8" Aspect="Uniform" HeightRequest="20" WidthRequest="20" VerticalOptions="Center" />
                                            <Entry Placeholder="Search warehouse items..." TextColor="#1E293B" PlaceholderColor="#94A3B8" BackgroundColor="Transparent" WidthRequest="300" VerticalOptions="Center" />
                                        </HorizontalStackLayout>
                                    </Border>

                                    <Button Grid.Column="1" Text="+ Record Delivery" BackgroundColor="#624890" TextColor="White" CornerRadius="24" HeightRequest="48" Padding="24,0" FontAttributes="Bold" />
                                </Grid>

                                <!-- Table -->
                                <Grid ColumnDefinitions="2*,1*,1*,1*,1*,Auto" Padding="0,0,0,12" RowDefinitions="Auto,Auto,Auto,Auto,Auto" RowSpacing="24">
                                    <!-- Headers -->
                                    <Label Grid.Row="0" Grid.Column="0" Text="Item Name" FontSize="12" FontAttributes="Bold" TextColor="#624890" />
                                    <Label Grid.Row="0" Grid.Column="1" Text="SKU" FontSize="12" FontAttributes="Bold" TextColor="#624890" />
                                    <Label Grid.Row="0" Grid.Column="2" Text="Category" FontSize="12" FontAttributes="Bold" TextColor="#624890" />
                                    <Label Grid.Row="0" Grid.Column="3" Text="Quantity" FontSize="12" FontAttributes="Bold" TextColor="#624890" />
                                    <Label Grid.Row="0" Grid.Column="4" Text="Status" FontSize="12" FontAttributes="Bold" TextColor="#624890" />
                                    <Label Grid.Row="0" Grid.Column="5" Text="Actions" FontSize="12" FontAttributes="Bold" TextColor="#624890" HorizontalTextAlignment="End" />
                                    
                                    <BoxView Grid.Row="0" Grid.ColumnSpan="6" HeightRequest="1" Color="#E2E8F0" VerticalOptions="End" Margin="0,0,0,-12" />

                                    <!-- Row 1 -->
                                    <Label Grid.Row="1" Grid.Column="0" Text="Premium Cotton Fabric" FontAttributes="Bold" TextColor="#1E293B" VerticalOptions="Center" />
                                    <Label Grid.Row="1" Grid.Column="1" Text="RM-001" TextColor="#64748B" VerticalOptions="Center" />
                                    <Label Grid.Row="1" Grid.Column="2" Text="Fabric" TextColor="#64748B" VerticalOptions="Center" />
                                    <Label Grid.Row="1" Grid.Column="3" Text="450 meters" FontAttributes="Bold" TextColor="#463366" VerticalOptions="Center" />
                                    <Border Grid.Row="1" Grid.Column="4" BackgroundColor="#DCFCE7" StrokeShape="RoundRectangle 12" Padding="12,4" HorizontalOptions="Start" VerticalOptions="Center" StrokeThickness="0">
                                        <Label Text="In Stock" TextColor="#15803D" FontSize="11" FontAttributes="Bold" />
                                    </Border>
                                    <Label Grid.Row="1" Grid.Column="5" Text="Edit" TextColor="#9333EA" FontSize="13" VerticalOptions="Center" HorizontalTextAlignment="End">
                                        <Label.GestureRecognizers><TapGestureRecognizer /></Label.GestureRecognizers>
                                    </Label>

                                    <!-- Row 2 -->
                                    <Label Grid.Row="2" Grid.Column="0" Text="Silk Thread (Purple)" FontAttributes="Bold" TextColor="#1E293B" VerticalOptions="Center" />
                                    <Label Grid.Row="2" Grid.Column="1" Text="RM-045" TextColor="#64748B" VerticalOptions="Center" />
                                    <Label Grid.Row="2" Grid.Column="2" Text="Thread" TextColor="#64748B" VerticalOptions="Center" />
                                    <Label Grid.Row="2" Grid.Column="3" Text="20 pcs" FontAttributes="Bold" TextColor="#463366" VerticalOptions="Center" />
                                    <Border Grid.Row="2" Grid.Column="4" BackgroundColor="#FEF3C7" StrokeShape="RoundRectangle 12" Padding="12,4" HorizontalOptions="Start" VerticalOptions="Center" StrokeThickness="0">
                                        <Label Text="Low Stock" TextColor="#D97706" FontSize="11" FontAttributes="Bold" />
                                    </Border>
                                    <Label Grid.Row="2" Grid.Column="5" Text="Edit" TextColor="#9333EA" FontSize="13" VerticalOptions="Center" HorizontalTextAlignment="End">
                                        <Label.GestureRecognizers><TapGestureRecognizer /></Label.GestureRecognizers>
                                    </Label>

                                    <!-- Row 3 -->
                                    <Label Grid.Row="3" Grid.Column="0" Text="Buttons (Gold, 12mm)" FontAttributes="Bold" TextColor="#1E293B" VerticalOptions="Center" />
                                    <Label Grid.Row="3" Grid.Column="1" Text="RM-102" TextColor="#64748B" VerticalOptions="Center" />
                                    <Label Grid.Row="3" Grid.Column="2" Text="Accessories" TextColor="#64748B" VerticalOptions="Center" />
                                    <Label Grid.Row="3" Grid.Column="3" Text="1500 pcs" FontAttributes="Bold" TextColor="#463366" VerticalOptions="Center" />
                                    <Border Grid.Row="3" Grid.Column="4" BackgroundColor="#DCFCE7" StrokeShape="RoundRectangle 12" Padding="12,4" HorizontalOptions="Start" VerticalOptions="Center" StrokeThickness="0">
                                        <Label Text="In Stock" TextColor="#15803D" FontSize="11" FontAttributes="Bold" />
                                    </Border>
                                    <Label Grid.Row="3" Grid.Column="5" Text="Edit" TextColor="#9333EA" FontSize="13" VerticalOptions="Center" HorizontalTextAlignment="End">
                                        <Label.GestureRecognizers><TapGestureRecognizer /></Label.GestureRecognizers>
                                    </Label>

                                    <!-- Row 4 -->
                                    <Label Grid.Row="4" Grid.Column="0" Text="Denim Fabric" FontAttributes="Bold" TextColor="#1E293B" VerticalOptions="Center" />
                                    <Label Grid.Row="4" Grid.Column="1" Text="RM-022" TextColor="#64748B" VerticalOptions="Center" />
                                    <Label Grid.Row="4" Grid.Column="2" Text="Fabric" TextColor="#64748B" VerticalOptions="Center" />
                                    <Label Grid.Row="4" Grid.Column="3" Text="5 meters" FontAttributes="Bold" TextColor="#463366" VerticalOptions="Center" />
                                    <Border Grid.Row="4" Grid.Column="4" BackgroundColor="#FEE2E2" StrokeShape="RoundRectangle 12" Padding="12,4" HorizontalOptions="Start" VerticalOptions="Center" StrokeThickness="0">
                                        <Label Text="Critical" TextColor="#DC2626" FontSize="11" FontAttributes="Bold" />
                                    </Border>
                                    <Label Grid.Row="4" Grid.Column="5" Text="Edit" TextColor="#9333EA" FontSize="13" VerticalOptions="Center" HorizontalTextAlignment="End">
                                        <Label.GestureRecognizers><TapGestureRecognizer /></Label.GestureRecognizers>
                                    </Label>
                                </Grid>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>
