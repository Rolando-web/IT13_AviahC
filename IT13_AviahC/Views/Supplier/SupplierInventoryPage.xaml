<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:IT13_AviahC.Views.Supplier.Components"
             xmlns:adminComp="clr-namespace:IT13_AviahC.Views.Admin.Components"
             x:Class="IT13_AviahC.Views.Supplier.SupplierInventoryPage"
             BackgroundColor="#F3F0FA">

    <Grid ColumnDefinitions="Auto,*">
        <!-- Sidebar -->
        <components:SupplierSidebarView Grid.Column="0" CurrentPage="SupplierInventory" />

        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <adminComp:AdminHeaderView Grid.Row="0" />

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="32" Spacing="24">

                    <!-- Title Row -->
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout VerticalOptions="Center" Spacing="4">
                            <Label Text="Warehouse Supply Management" FontSize="28" FontAttributes="Bold" TextColor="#463366" />
                            <Label Text="Add, update or remove raw materials you supply to Aviah Collection."
                                   FontSize="13" TextColor="#94A3B8" />
                        </VerticalStackLayout>
                        <HorizontalStackLayout Grid.Column="1" Spacing="12" VerticalOptions="Center">
                            <Button Text="↻ Refresh" BackgroundColor="White" TextColor="#624890"
                                    CornerRadius="12" Padding="20,0" HeightRequest="44"
                                    FontAttributes="Bold" Clicked="OnRefreshClicked" />
                            <Button Text="+ Record Delivery" BackgroundColor="#624890" TextColor="White"
                                    CornerRadius="12" Padding="24,0" HeightRequest="44"
                                    FontAttributes="Bold" Clicked="OnAddItemClicked" />
                        </HorizontalStackLayout>
                    </Grid>

                    <!-- Summary Cards -->
                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="16">
                        <Border BackgroundColor="White" StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="20">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Total Items" FontSize="13" TextColor="#64748B" />
                                <Label x:Name="TotalItemsLabel" Text="0" FontSize="32" FontAttributes="Bold" TextColor="#463366" />
                                <Label Text="Raw Materials" FontSize="12" TextColor="#94A3B8" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" BackgroundColor="#FEF3C7" StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="20">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Low Stock" FontSize="13" TextColor="#D97706" />
                                <Label x:Name="LowStockLabel" Text="0" FontSize="32" FontAttributes="Bold" TextColor="#D97706" />
                                <Label Text="Items to resupply" FontSize="12" TextColor="#FCD34D" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="2" BackgroundColor="#FEE2E2" StrokeShape="RoundRectangle 16" StrokeThickness="0" Padding="20">
                            <VerticalStackLayout Spacing="6">
                                <Label Text="Critical" FontSize="13" TextColor="#DC2626" />
                                <Label x:Name="CriticalLabel" Text="0" FontSize="32" FontAttributes="Bold" TextColor="#DC2626" />
                                <Label Text="Urgent restocking" FontSize="12" TextColor="#FCA5A5" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Table Card -->
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 20" StrokeThickness="0" Padding="0">
                        <VerticalStackLayout>
                            <!-- Table Header -->
                            <Grid ColumnDefinitions="*,Auto,Auto,*,Auto" Padding="24,16"
                                  BackgroundColor="#F3F0FA" ColumnSpacing="12">
                                <Label Text="Item Name / SKU" FontAttributes="Bold" FontSize="13" TextColor="#624890" />
                                <Label Grid.Column="1" Text="Category" FontAttributes="Bold" FontSize="13" TextColor="#624890" />
                                <Label Grid.Column="2" Text="Quantity" FontAttributes="Bold" FontSize="13" TextColor="#624890" />
                                <Label Grid.Column="3" Text="Status" FontAttributes="Bold" FontSize="13" TextColor="#624890" />
                                <Label Grid.Column="4" Text="Actions" FontAttributes="Bold" FontSize="13"
                                       TextColor="#624890" HorizontalTextAlignment="End" WidthRequest="120" />
                            </Grid>

                            <!-- Rows -->
                            <CollectionView x:Name="WarehouseCollection">
                                <CollectionView.EmptyView>
                                    <VerticalStackLayout Padding="40" Spacing="8" HorizontalOptions="Center">
                                        <Label Text="No materials found." FontSize="16" FontAttributes="Bold"
                                               TextColor="#64748B" HorizontalTextAlignment="Center" />
                                        <Label Text="Click '+ Record Delivery' to add a raw material supply."
                                               FontSize="13" TextColor="#94A3B8" HorizontalTextAlignment="Center" />
                                    </VerticalStackLayout>
                                </CollectionView.EmptyView>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <VerticalStackLayout>
                                            <Grid ColumnDefinitions="*,Auto,Auto,*,Auto" Padding="24,16" ColumnSpacing="12">
                                                <!-- Name + SKU -->
                                                <VerticalStackLayout VerticalOptions="Center" Spacing="2">
                                                    <Label Text="{Binding ItemName}" FontAttributes="Bold" FontSize="14" TextColor="#1E293B" />
                                                    <Label Text="{Binding MaterialID}" FontSize="12" TextColor="#94A3B8" />
                                                </VerticalStackLayout>
                                                <!-- Category -->
                                                <Label Grid.Column="1" Text="{Binding Category}" FontSize="13" TextColor="#64748B" VerticalOptions="Center" />
                                                <!-- Quantity + Unit -->
                                                <HorizontalStackLayout Grid.Column="2" Spacing="4" VerticalOptions="Center">
                                                    <Label Text="{Binding Quantity}" FontAttributes="Bold" FontSize="15" TextColor="#463366" />
                                                    <Label Text="{Binding Unit}" FontSize="12" TextColor="#94A3B8" VerticalOptions="End" Margin="0,0,0,1" />
                                                </HorizontalStackLayout>
                                                <!-- Status Pill -->
                                                <Border Grid.Column="3" StrokeShape="RoundRectangle 12" Padding="12,4"
                                                        StrokeThickness="0" BackgroundColor="{Binding StatusBg}"
                                                        HorizontalOptions="Start" VerticalOptions="Center">
                                                    <Label Text="{Binding Status}" FontSize="12" TextColor="{Binding StatusFg}" FontAttributes="Bold" />
                                                </Border>
                                                <!-- Action Buttons -->
                                                <HorizontalStackLayout Grid.Column="4" Spacing="12"
                                                                       HorizontalOptions="End" VerticalOptions="Center">
                                                    <Label Text="Edit" TextColor="#624890" FontSize="13"
                                                           TextDecorations="Underline" VerticalOptions="Center">
                                                        <Label.GestureRecognizers>
                                                            <TapGestureRecognizer Tapped="OnEditItemClicked"
                                                                                  CommandParameter="{Binding .}" />
                                                        </Label.GestureRecognizers>
                                                    </Label>
                                                    <Label Text="Del" TextColor="#EF4444" FontSize="13"
                                                           TextDecorations="Underline" VerticalOptions="Center">
                                                        <Label.GestureRecognizers>
                                                            <TapGestureRecognizer Tapped="OnDeleteItemClicked"
                                                                                  CommandParameter="{Binding .}" />
                                                        </Label.GestureRecognizers>
                                                    </Label>
                                                </HorizontalStackLayout>
                                            </Grid>
                                            <BoxView HeightRequest="1" BackgroundColor="#F1F5F9" Margin="24,0" />
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!-- ADD / EDIT MODAL OVERLAY -->
        <Grid x:Name="ModalOverlay" Grid.ColumnSpan="2" IsVisible="False"
              BackgroundColor="#80000000">
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 24"
                    HorizontalOptions="Center" VerticalOptions="Center"
                    WidthRequest="480" Padding="32">
                <VerticalStackLayout Spacing="20">
                    <!-- Header -->
                    <Grid ColumnDefinitions="*,Auto">
                        <Label x:Name="ModalTitle" Text="Record Material Delivery"
                               FontSize="20" FontAttributes="Bold" TextColor="#463366" VerticalOptions="Center" />
                        <Button Grid.Column="1" Text="✕" BackgroundColor="Transparent"
                                TextColor="#94A3B8" FontSize="18" Clicked="OnCloseModalClicked" />
                    </Grid>

                    <!-- Material ID / SKU -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Material ID (SKU)" FontSize="13" FontAttributes="Bold" TextColor="#1E293B" />
                        <Border StrokeShape="RoundRectangle 10" Stroke="#E2E8F0" Padding="14,10">
                            <Entry x:Name="SkuEntry" Placeholder="e.g. RM-001"
                                   PlaceholderColor="#94A3B8" TextColor="#1E293B" BackgroundColor="Transparent" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Item Name -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Item Name" FontSize="13" FontAttributes="Bold" TextColor="#1E293B" />
                        <Border StrokeShape="RoundRectangle 10" Stroke="#E2E8F0" Padding="14,10">
                            <Entry x:Name="NameEntry" Placeholder="e.g. Premium Cotton Fabric"
                                   PlaceholderColor="#94A3B8" TextColor="#1E293B" BackgroundColor="Transparent" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Category -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Category" FontSize="13" FontAttributes="Bold" TextColor="#1E293B" />
                        <Border StrokeShape="RoundRectangle 10" Stroke="#E2E8F0" Padding="8,4">
                            <Picker x:Name="CategoryPicker" Title="Select category"
                                    TextColor="#1E293B" TitleColor="#94A3B8">
                                <Picker.Items>
                                    <x:String>Fabric</x:String>
                                    <x:String>Thread</x:String>
                                    <x:String>Accessories</x:String>
                                    <x:String>Packaging</x:String>
                                    <x:String>Dye &amp; Color</x:String>
                                    <x:String>Hardware</x:String>
                                    <x:String>Other</x:String>
                                </Picker.Items>
                            </Picker>
                        </Border>
                    </VerticalStackLayout>

                    <!-- Quantity + Unit -->
                    <Grid ColumnDefinitions="2*,*" ColumnSpacing="12">
                        <VerticalStackLayout Spacing="6">
                            <Label Text="Quantity Supplied" FontSize="13" FontAttributes="Bold" TextColor="#1E293B" />
                            <Border StrokeShape="RoundRectangle 10" Stroke="#E2E8F0" Padding="14,10">
                                <Entry x:Name="QuantityEntry" Placeholder="0" Keyboard="Numeric"
                                       PlaceholderColor="#94A3B8" TextColor="#1E293B" BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="6">
                            <Label Text="Unit" FontSize="13" FontAttributes="Bold" TextColor="#1E293B" />
                            <Border StrokeShape="RoundRectangle 10" Stroke="#E2E8F0" Padding="8,4">
                                <Picker x:Name="UnitPicker" Title="Unit" TextColor="#1E293B" TitleColor="#94A3B8">
                                    <Picker.Items>
                                        <x:String>meters</x:String>
                                        <x:String>pcs</x:String>
                                        <x:String>kg</x:String>
                                        <x:String>liters</x:String>
                                        <x:String>rolls</x:String>
                                        <x:String>boxes</x:String>
                                    </Picker.Items>
                                </Picker>
                            </Border>
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Actions -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,8,0,0">
                        <Button Text="Cancel" BackgroundColor="#F1F5F9" TextColor="#64748B"
                                CornerRadius="12" HeightRequest="48" FontAttributes="Bold"
                                Clicked="OnCloseModalClicked" />
                        <Button Grid.Column="1" Text="Save" BackgroundColor="#624890"
                                TextColor="White" CornerRadius="12" HeightRequest="48"
                                FontAttributes="Bold" Clicked="OnSaveItemClicked" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
