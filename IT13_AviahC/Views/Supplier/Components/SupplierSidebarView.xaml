<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IT13_AviahC.Views.Supplier.Components.SupplierSidebarView">
    <Grid RowDefinitions="Auto,*,Auto" WidthRequest="260" BackgroundColor="#624890" Padding="0,32">
        <!-- Logo -->
        <HorizontalStackLayout Grid.Row="0" Spacing="12" Padding="24,0,24,32">
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 10" HeightRequest="32" WidthRequest="32" StrokeThickness="0">
                <Label Text="A" TextColor="#624890" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
            </Border>
            <Label Text="Aviah System" TextColor="White" FontSize="20" FontAttributes="Bold" VerticalOptions="Center" />
        </HorizontalStackLayout>

        <!-- Nav Items -->
        <VerticalStackLayout Grid.Row="1" Spacing="4">
            <Label Text="SUPPLIER MODULES" TextColor="#B0A4D4" FontSize="11" FontAttributes="Bold" Margin="24,0,24,12" CharacterSpacing="1" />
            
            <Grid Padding="24,12" ColumnDefinitions="Auto,*" BackgroundColor="{Binding DashboardBg}">
                <Path Data="M3,13h8V3H3V13z M3,21h8v-6H3V21z M13,21h8V11h-8V21z M13,3v6h8V3H13V3z" Fill="{Binding DashboardColor}" Aspect="Uniform" HeightRequest="18" WidthRequest="18" />
                <Label Grid.Column="1" Text="Dashboard" TextColor="{Binding DashboardColor}" FontSize="15" Margin="12,0" VerticalOptions="Center" FontAttributes="Bold" />
                <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnDashboardClicked" /></Grid.GestureRecognizers>
            </Grid>

            <Grid Padding="24,12" ColumnDefinitions="Auto,*" BackgroundColor="{Binding InventoryBg}">
                <Path Data="M12,2L2,7l10,5,10-5L12,2z M2,17l10,5,10-5M2,12l10,5,10-5" Fill="{Binding InventoryColor}" Aspect="Uniform" HeightRequest="18" WidthRequest="18" />
                <Label Grid.Column="1" Text="Inventory" TextColor="{Binding InventoryColor}" FontSize="15" Margin="12,0" VerticalOptions="Center" />
                <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnInventoryClicked" /></Grid.GestureRecognizers>
            </Grid>
        </VerticalStackLayout>

        <!-- Footer / Logout -->
        <Grid Grid.Row="2" Padding="24,0" ColumnDefinitions="Auto,*" VerticalOptions="End">
            <Path Data="M10.09 15.59L11.5 17l5-5-5-5-1.41 1.41L12.67 11H3v2h9.67l-2.58 2.59zM19 3H5c-1.11 0-2 .9-2 2v4h2V5h14v14H5v-4H3v4c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z" Fill="#D1C4E9" Aspect="Uniform" HeightRequest="18" WidthRequest="18" />
            <Label Grid.Column="1" Text="Logout" TextColor="#D1C4E9" FontSize="15" Margin="12,0" VerticalOptions="Center" />
            <Grid.GestureRecognizers><TapGestureRecognizer Tapped="OnLogoutClicked" /></Grid.GestureRecognizers>
        </Grid>
    </Grid>
</ContentView>
