<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:IT13_AviahC.Views.DeliveryStaff.Components"
             xmlns:adminComp="clr-namespace:IT13_AviahC.Views.Admin.Components"
             xmlns:models="clr-namespace:IT13_AviahC.Models"
             x:Class="IT13_AviahC.Views.DeliveryStaff.DeliveryStaffLogisticsPage"
             BackgroundColor="#F3F0FA">

    <Grid ColumnDefinitions="Auto,*">
        <!-- Sidebar -->
        <components:DeliveryStaffSidebarView Grid.Column="0" CurrentPage="DeliveryStaffLogistics" />

        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <adminComp:AdminHeaderView Grid.Row="0" />

            <ScrollView Grid.Row="1">
                <Grid ColumnDefinitions="*,340" ColumnSpacing="24" Padding="32">
                    <!-- Left: Deliveries List -->
                    <VerticalStackLayout Grid.Column="0" Spacing="24">
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout>
                                <Label Text="Delivery Logistics" FontSize="24" FontAttributes="Bold" TextColor="#463366" />
                                <Label Text="Active Deliveries" FontSize="16" FontAttributes="Bold" TextColor="#7D6A9E" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1" Text="View Delivered Orders" Clicked="OnViewDeliveredClicked" 
                                    BackgroundColor="#F0FDF4" TextColor="#166534" CornerRadius="12" HeightRequest="40" Padding="15,0" />
                        </Grid>

                        <CollectionView x:Name="DeliveriesCollection">
                            <CollectionView.EmptyView>
                                <VerticalStackLayout Padding="40" Spacing="12" HorizontalOptions="Center">
                                    <Label Text="No active deliveries" FontSize="18" FontAttributes="Bold" TextColor="#64748B" HorizontalTextAlignment="Center" />
                                    <Label Text="All clear! No pending packages to track." FontSize="14" TextColor="#94A3B8" HorizontalTextAlignment="Center" />
                                </VerticalStackLayout>
                            </CollectionView.EmptyView>
                            <CollectionView.ItemTemplate>
                                <DataTemplate x:DataType="models:DeliveryItem">
                                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="24" StrokeThickness="0" Margin="0,0,0,24">
                                        <VerticalStackLayout Spacing="20">
                                            <Grid ColumnDefinitions="Auto,*,Auto">
                                                <!-- Product Image -->
                                                <Border Grid.Column="0" BackgroundColor="#F1F5F9" StrokeShape="RoundRectangle 12" HeightRequest="64" WidthRequest="64" StrokeThickness="0">
                                                    <Image Source="{Binding ProductImage}" Aspect="AspectFill" />
                                                </Border>

                                                <!-- Info -->
                                                <VerticalStackLayout Grid.Column="1" Margin="20,0" Spacing="4">
                                                    <HorizontalStackLayout Spacing="12">
                                                        <Label Text="{Binding DeliveryID}" FontAttributes="Bold" FontSize="18" TextColor="#463366" />
                                                        <Border BackgroundColor="{Binding StatusBgLight}" StrokeShape="RoundRectangle 8" Padding="12,2" StrokeThickness="0" VerticalOptions="Center">
                                                            <Label Text="{Binding Status}" FontSize="10" TextColor="{Binding StatusColorDark}" FontAttributes="Bold" />
                                                        </Border>
                                                    </HorizontalStackLayout>
                                                    <HorizontalStackLayout Spacing="8">
                                                        <Label Text="Ref:" FontSize="13" TextColor="#94A3B8" />
                                                        <Label Text="{Binding OrderRef}" FontSize="13" TextColor="#64748B" FontAttributes="Bold" />
                                                        <Label Text="•" FontSize="13" TextColor="#94A3B8" />
                                                        <Label Text="{Binding CustomerName}" FontSize="13" TextColor="#64748B" />
                                                    </HorizontalStackLayout>
                                                    
                                                    <Grid ColumnDefinitions="Auto,Auto" ColumnSpacing="20" Margin="0,8,0,0">
                                                        <HorizontalStackLayout Spacing="8">
                                                            <Path Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zM12.5 7H11v6l5.25 3.15.75-1.23-4.5-2.67z" 
                                                                  Fill="#94A3B8" Aspect="Uniform" HeightRequest="14" WidthRequest="14" VerticalOptions="Center" />
                                                            <Label Text="ETA:" FontSize="13" TextColor="#94A3B8" VerticalOptions="Center" />
                                                            <Label Text="{Binding ETA}" FontSize="13" TextColor="#463366" FontAttributes="Bold" VerticalOptions="Center" />
                                                        </HorizontalStackLayout>
                                                        <HorizontalStackLayout Grid.Column="1" Spacing="8">
                                                            <Path Data="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" 
                                                                  Fill="#94A3B8" Aspect="Uniform" HeightRequest="14" WidthRequest="14" VerticalOptions="Center" />
                                                            <Label Text="{Binding DriverName}" FontSize="13" TextColor="#64748B" VerticalOptions="Center" />
                                                        </HorizontalStackLayout>
                                                    </Grid>
                                                </VerticalStackLayout>

                                                <!-- Location Stats -->
                                                <VerticalStackLayout Grid.Column="2" Spacing="10" HorizontalOptions="End" VerticalOptions="Center">
                                                    <HorizontalStackLayout Spacing="8" HorizontalOptions="End">
                                                        <Path Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25zM20.71 7.04c.39-.39.39-1.02 0-1.41l-2.34-2.34c-.39-.39-1.02-.39-1.41 0l-1.83 1.83 3.75 3.75 1.83-1.83z" 
                                                              Fill="#94A3B8" Aspect="Uniform" HeightRequest="14" WidthRequest="14" VerticalOptions="Center" />
                                                        <Label Text="Current:" FontSize="12" TextColor="#94A3B8" />
                                                        <Label Text="{Binding CurrentLocation}" FontSize="12" TextColor="#1E293B" FontAttributes="Bold" />
                                                    </HorizontalStackLayout>
                                                    <HorizontalStackLayout Spacing="8" HorizontalOptions="End">
                                                        <Path Data="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z" 
                                                              Fill="#94A3B8" Aspect="Uniform" HeightRequest="14" WidthRequest="14" VerticalOptions="Center" />
                                                        <Label Text="Dest:" FontSize="12" TextColor="#94A3B8" />
                                                        <Label Text="{Binding Destination}" FontSize="12" TextColor="#1E293B" FontAttributes="Bold" />
                                                    </HorizontalStackLayout>
                                                </VerticalStackLayout>
                                            </Grid>

                                            <!-- Update Button -->
                                            <Button Text="✎ Update Delivery Status" BackgroundColor="#F1F5F9" TextColor="#624890" 
                                                    CornerRadius="12" FontAttributes="Bold" FontSize="13" HeightRequest="44" 
                                                    Clicked="OnUpdateDeliveryClicked" CommandParameter="{Binding .}" />
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                    </VerticalStackLayout>

                    <!-- Right: Quick Assign -->
                    <VerticalStackLayout Grid.Column="1" Spacing="24">
                        <Border BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="32" StrokeThickness="0">
                            <VerticalStackLayout Spacing="24">
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="Quick Assign" FontSize="18" FontAttributes="Bold" TextColor="#463366" />
                                    <Label Text="Assign pending deliveries to available drivers." FontSize="12" TextColor="#94A3B8" />
                                </VerticalStackLayout>

                                <VerticalStackLayout Spacing="8">
                                    <Label Text="Delivery ID" FontSize="13" FontAttributes="Bold" TextColor="#463366" />
                                    <Border BackgroundColor="#F8FAFC" StrokeShape="RoundRectangle 12" Padding="4" StrokeThickness="0">
                                        <Picker x:Name="PendingDeliveryPicker" Title="Select Delivery" TextColor="#1E293B" FontSize="14" />
                                    </Border>
                                </VerticalStackLayout>

                                <Button Text="Assign Delivery" BackgroundColor="#624890" TextColor="White" CornerRadius="12" 
                                        FontAttributes="Bold" HeightRequest="48" Margin="0,8,0,0" Clicked="OnAssignClicked" />
                            </VerticalStackLayout>
                        </Border>

                        <!-- Load Summary -->
                        <Border BackgroundColor="#624890" StrokeShape="RoundRectangle 24" Padding="24" StrokeThickness="0">
                            <VerticalStackLayout Spacing="12">
                                <HorizontalStackLayout Spacing="10">
                                    <Path Data="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4z" 
                                          Fill="White" Aspect="Uniform" HeightRequest="16" WidthRequest="16" VerticalOptions="Center" />
                                    <Label Text="Today's Load" TextColor="White" FontAttributes="Bold" FontSize="14" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <Label x:Name="TotalLoadLabel" Text="0" TextColor="White" FontSize="32" FontAttributes="Bold" />
                                <Label Text="Packages scheduled for delivery" TextColor="#D1C4E9" FontSize="12" />
                            </VerticalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </Grid>
            </ScrollView>
        </Grid>

        <!-- STATUS UPDATE MODAL -->
        <Grid x:Name="UpdateModalOverlay" Grid.ColumnSpan="2" IsVisible="False" BackgroundColor="#80000000">
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 32" HorizontalOptions="Center" VerticalOptions="Center" WidthRequest="520" Padding="0" StrokeThickness="0">
                <VerticalStackLayout Spacing="0">
                    <!-- Modal Header -->
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="24,20" BackgroundColor="#F3F0FA">
                        <Path Data="M3 17.25V21h3.75L17.81 9.94l-3.75-3.75L3 17.25z" 
                              Fill="#624890" Aspect="Uniform" HeightRequest="18" WidthRequest="18" VerticalOptions="Center" />
                        <Label x:Name="UpdateModalTitle" Grid.Column="1" Text="Update Order Status: DEL-8401" 
                               FontSize="16" FontAttributes="Bold" TextColor="#463366" VerticalOptions="Center" Margin="12,0" />
                        <Button Grid.Column="2" Text="✕" Clicked="OnCloseUpdateModalClicked" BackgroundColor="Transparent" TextColor="#624890" FontSize="18" Padding="0" />
                    </Grid>

                    <VerticalStackLayout Padding="32" Spacing="24">
                        <!-- Location Entry -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Location/Details" FontSize="13" FontAttributes="Bold" TextColor="#463366" />
                            <Border BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="12">
                                <Entry x:Name="ModalLocationEntry" Placeholder="e.g., SPX Service Point - Akira Online Shop, SOC 5, etc." 
                                       PlaceholderColor="#94A3B8" TextColor="#1E293B" BackgroundColor="Transparent" />
                            </Border>
                        </VerticalStackLayout>

                        <!-- Status Picker (Moved to bottom) -->
                        <VerticalStackLayout Spacing="8">
                            <Label Text="Status Update" FontSize="13" FontAttributes="Bold" TextColor="#463366" />
                            <Border BackgroundColor="White" Stroke="#E2E8F0" StrokeThickness="1" StrokeShape="RoundRectangle 12" Padding="4">
                                <Picker x:Name="ModalStatusPicker" Title="Select status..." TextColor="#1E293B">
                                    <Picker.Items>
                                        <x:String>Order placed</x:String>
                                        <x:String>Preparing to ship</x:String>
                                        <x:String>Your parcel has been picked up by our logistics partner</x:String>
                                        <x:String>Parcel has been received at dropoff point</x:String>
                                        <x:String>Parcel has arrived at sorting facility</x:String>
                                        <x:String>Parcel is loaded into truck, to leave sorting center soon</x:String>
                                        <x:String>Parcel has departed from sorting facility</x:String>
                                        <x:String>The order is in transit and is on its way to the next location</x:String>
                                        <x:String>Out for delivery</x:String>
                                        <x:String>Package delivered successfully</x:String>
                                    </Picker.Items>
                                </Picker>
                            </Border>
                        </VerticalStackLayout>

                        <!-- Actions -->
                        <Grid ColumnDefinitions="*,120" ColumnSpacing="16">
                            <Button Text="Confirm Update" Clicked="OnConfirmUpdateClicked" BackgroundColor="#624890" TextColor="White" 
                                    CornerRadius="12" FontAttributes="Bold" HeightRequest="52">
                                <Button.ImageSource>
                                    <FontImageSource Glyph="✓" Color="White" Size="18" />
                                </Button.ImageSource>
                            </Button>
                            <Button Grid.Column="1" Text="Cancel" Clicked="OnCloseUpdateModalClicked" BackgroundColor="White" BorderColor="#E2E8F0" BorderWidth="1" 
                                    TextColor="#64748B" CornerRadius="12" FontAttributes="Bold" HeightRequest="52" />
                        </Grid>

                        <!-- Info Box -->
                        <Border BackgroundColor="#EFF6FF" StrokeShape="RoundRectangle 12" Padding="16" StrokeThickness="0">
                            <HorizontalStackLayout Spacing="12">
                                <Label Text="💡" VerticalOptions="Center" />
                                <Label Text="This update will be visible to the customer in real-time on their order tracking page." 
                                       TextColor="#2563EB" FontSize="12" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
