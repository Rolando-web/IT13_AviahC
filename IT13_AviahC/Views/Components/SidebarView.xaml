<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui" 
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" 
             x:Class="IT13_AviahC.Views.Components.SidebarView" 
             x:Name="generalSidebar"
             WidthRequest="240"
             MinimumWidthRequest="240"
             HorizontalOptions="Start" 
             VerticalOptions="Fill">
    <Grid x:Name="RootGrid"
          BindingContext="{Binding Source={x:Reference generalSidebar}}"
          BackgroundColor="#624890"
          Padding="16,24"
          RowDefinitions="Auto,*,Auto">
        
        <!-- Header -->
        <VerticalStackLayout Spacing="24" Margin="8,0,0,32">
            <HorizontalStackLayout Spacing="12">
                <Border BackgroundColor="#7B5EB0"
                        StrokeShape="RoundRectangle 10"
                        HeightRequest="40"
                        WidthRequest="40">
                    <Label Text="A"
                           TextColor="White"
                           FontAttributes="Bold"
                           FontSize="20"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
                <Label Text="Aviah System"
                       TextColor="White"
                       FontAttributes="Bold"
                       FontSize="20"
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
            <Label Text="{Binding ModuleTitle}"
                   TextColor="#D1C4E9"
                   FontAttributes="Bold"
                   CharacterSpacing="1"
                   FontSize="12" 
                   Opacity="0.7"/>
        </VerticalStackLayout>

        <!-- Navigation Links -->
        <ScrollView Grid.Row="1">
            <VerticalStackLayout Spacing="6">
                
                <!-- Superadmin Dashboard -->
                <Border Stroke="Transparent" StrokeShape="RoundRectangle 12" Padding="12,12" BackgroundColor="Transparent">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="SuperadminDashboard" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="30,*" ColumnSpacing="12">
                        <Path Data="M3 3h7v7H3V3zm11 0h7v7h-7V3zm0 11h7v7h-7v-7zM3 14h7v7H3v-7z"
                               Fill="White"
                               Aspect="Uniform"
                               HeightRequest="18"
                               WidthRequest="18"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Dashboard" TextColor="White" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                    </Grid>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding CurrentPage}" Value="SuperadminDashboard">
                            <Setter Property="BackgroundColor" Value="#463366" />
                        </DataTrigger>
                    </Border.Triggers>
                </Border>

                <!-- Customers -->
                <Border Stroke="Transparent" StrokeShape="RoundRectangle 12" Padding="12,12" BackgroundColor="Transparent">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="SuperadminCustomers" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="30,*" ColumnSpacing="12">
                        <Path Data="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"
                               Fill="White"
                               Aspect="Uniform"
                               HeightRequest="18"
                               WidthRequest="18"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Customers CRM" TextColor="White" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                    </Grid>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding CurrentPage}" Value="SuperadminCustomers">
                            <Setter Property="BackgroundColor" Value="#463366" />
                        </DataTrigger>
                    </Border.Triggers>
                </Border>

                <!-- Reports -->
                <Border Stroke="Transparent" StrokeShape="RoundRectangle 12" Padding="12,12" BackgroundColor="Transparent">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="SuperadminReports" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="30,*" ColumnSpacing="12">
                        <Path Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"
                               Fill="White"
                               Aspect="Uniform"
                               HeightRequest="18"
                               WidthRequest="18"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Global Reports" TextColor="White" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                    </Grid>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding CurrentPage}" Value="SuperadminReports">
                            <Setter Property="BackgroundColor" Value="#463366" />
                        </DataTrigger>
                    </Border.Triggers>
                </Border>

                <!-- Subscription -->
                <Border Stroke="Transparent" StrokeShape="RoundRectangle 12" Padding="12,12" BackgroundColor="Transparent">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="SuperadminSubscription" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="30,*" ColumnSpacing="12">
                        <Path Data="M5 16L3 5l5.5 5L12 4l3.5 6L21 5l-2 11H5zm14 3c0 .55-.45 1-1 1H6c-.55 0-1-.45-1-1v-1h14v1z"
                               Fill="White"
                               Aspect="Uniform"
                               HeightRequest="18"
                               WidthRequest="18"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Subscription" TextColor="White" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                    </Grid>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding CurrentPage}" Value="SuperadminSubscription">
                            <Setter Property="BackgroundColor" Value="#463366" />
                        </DataTrigger>
                    </Border.Triggers>
                </Border>

                <!-- Audit Logs -->
                <Border Stroke="Transparent" StrokeShape="RoundRectangle 12" Padding="12,12" BackgroundColor="Transparent">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="SuperadminAuditLogs" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="30,*" ColumnSpacing="12">
                        <Path Data="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"
                               Fill="White"
                               Aspect="Uniform"
                               HeightRequest="18"
                               WidthRequest="18"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Audit Logs" TextColor="White" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                    </Grid>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding CurrentPage}" Value="SuperadminAuditLogs">
                            <Setter Property="BackgroundColor" Value="#463366" />
                        </DataTrigger>
                    </Border.Triggers>
                </Border>

                <!-- Terms -->
                <Border Stroke="Transparent" StrokeShape="RoundRectangle 12" Padding="12,12" BackgroundColor="Transparent">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="SuperadminTerms" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="30,*" ColumnSpacing="12">
                        <Path Data="M14 2H6c-1.1 0-1.99.9-1.99 2L4 20c0 1.1.89 2 1.99 2H18c1.1 0 2-.9 2-2V8l-6-6zm2 16H8v-2h8v2zm0-4H8v-2h8v2zm-3-5V3.5L18.5 9H13z"
                               Fill="White"
                               Aspect="Uniform"
                               HeightRequest="18"
                               WidthRequest="18"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="Terms &amp; Conditions" TextColor="White" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                    </Grid>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding CurrentPage}" Value="SuperadminTerms">
                            <Setter Property="BackgroundColor" Value="#463366" />
                        </DataTrigger>
                    </Border.Triggers>
                </Border>

                <!-- Settings -->
                <Border Stroke="Transparent" StrokeShape="RoundRectangle 12" Padding="12,12" BackgroundColor="Transparent">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="SuperadminSettings" />
                    </Border.GestureRecognizers>
                    <Grid ColumnDefinitions="30,*" ColumnSpacing="12">
                        <Path Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.22.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"
                               Fill="White"
                               Aspect="Uniform"
                               HeightRequest="18"
                               WidthRequest="18"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                        <Label Grid.Column="1" Text="System Settings" TextColor="White" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                    </Grid>
                    <Border.Triggers>
                        <DataTrigger TargetType="Border" Binding="{Binding CurrentPage}" Value="SuperadminSettings">
                            <Setter Property="BackgroundColor" Value="#463366" />
                        </DataTrigger>
                    </Border.Triggers>
                </Border>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Footer -->
        <VerticalStackLayout Grid.Row="2" Spacing="8" Margin="0,20,0,0">
            <BoxView HeightRequest="1" BackgroundColor="#7B5EB0" Margin="0,0,0,16" />
            <Border Stroke="Transparent" StrokeShape="RoundRectangle 12" Padding="12,12" BackgroundColor="Transparent">
                <Border.GestureRecognizers>
                    <TapGestureRecognizer Command="{Binding NavigateCommand}" CommandParameter="Login" />
                </Border.GestureRecognizers>
                <Grid ColumnDefinitions="30,*" ColumnSpacing="12">
                    <Path Data="M10.09 15.59 L11.5 17 l 5 -5 -5 -5 -1.41 1.41 L12.67 11 H3 v2 h9.67 l -2.58 2.59 z M19 3 H5 c -1.11 0 -2 0.9 -2 2 v4 h2 V5 h14 v14 H5 v-4 H3 v4 c 0 1.1 0.89 2 2 2 h14 c 1.1 0 2 -0.9 2 -2 V5 c 0 -1.1 -0.9 -2 -2 -2 z"
                          Fill="White"
                          Aspect="Uniform"
                          HeightRequest="18"
                          WidthRequest="18"
                          HorizontalOptions="Center"
                          VerticalOptions="Center" />
                    <Label Grid.Column="1" Text="Logout" TextColor="White" FontSize="14" FontAttributes="Bold" VerticalOptions="Center" />
                </Grid>
            </Border>
        </VerticalStackLayout>
    </Grid>
</ContentView>
