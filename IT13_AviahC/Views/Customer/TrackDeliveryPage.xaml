<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:IT13_AviahC.Views.Customer.Components"
             x:Class="IT13_AviahC.Views.Customer.TrackDeliveryPage"
             BackgroundColor="#F8FAFC"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0">
            <components:CustomerHeaderView ActiveTab="Track" />

            <VerticalStackLayout Padding="40" Spacing="32">
                <!-- Promo Banner -->
                <Border BackgroundColor="#8B5CF6" StrokeShape="RoundRectangle 24" Padding="32" StrokeThickness="0">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="20">
                        <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                            <HorizontalStackLayout Spacing="8">
                                <Label Text="★" TextColor="#FBBF24" FontSize="20" VerticalOptions="Center"/>
                                <Label Text="Track Your Orders" TextColor="White" FontSize="20" FontAttributes="Bold" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Label Text="Stay updated with your order's journey in real-time." TextColor="#E9D5FF" FontSize="14" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="Shop New Arrivals" BackgroundColor="White" TextColor="#624890" CornerRadius="20" Padding="24,10" FontAttributes="Bold" VerticalOptions="Center"/>
                    </Grid>
                </Border>

                <!-- Empty State View -->
                <VerticalStackLayout x:Name="EmptyStateView" Spacing="24" Padding="60" IsVisible="False" HorizontalOptions="Center" VerticalOptions="Center">
                    <Border BackgroundColor="#F1F5F9" StrokeShape="RoundRectangle 50" HeightRequest="100" WidthRequest="100" StrokeThickness="0">
                        <Path Data="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zm-14 9c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm13 0c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z" Fill="#94A3B8" HeightRequest="40" WidthRequest="40" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="No Active Orders" FontSize="24" FontAttributes="Bold" TextColor="#1E293B" HorizontalTextAlignment="Center" />
                        <Label Text="You don't have any orders being delivered right now. Start shopping to see your orders here!" FontSize="14" TextColor="#64748B" HorizontalTextAlignment="Center" MaxWidthRequest="400" />
                    </VerticalStackLayout>
                    <Button Text="Start Shopping" BackgroundColor="#624890" TextColor="White" CornerRadius="12" Padding="32,16" FontAttributes="Bold" HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Tracking Content -->
                <VerticalStackLayout x:Name="TrackingContent" Spacing="32" IsVisible="True">
                    <!-- Order Status Card -->
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="40" StrokeThickness="0">
                        <VerticalStackLayout Spacing="40">
                            <HorizontalStackLayout Spacing="12" VerticalOptions="Center">
                                <Label Text="Order Status:" FontSize="20" FontAttributes="Bold" TextColor="#463366" />
                                <Label x:Name="OrderRefLabel" Text="#ORD-00000" FontSize="20" FontAttributes="Bold" TextColor="#8B5CF6" />
                            </HorizontalStackLayout>
    
                            <!-- Timeline -->
                            <Grid ColumnDefinitions="*,*,*,*,*" RowDefinitions="Auto,Auto,Auto" HorizontalOptions="Fill">
                                <!-- Line Background -->
                                <BoxView Grid.Row="1" Grid.ColumnSpan="5" HeightRequest="2" BackgroundColor="#E2E8F0" VerticalOptions="Center" Margin="40,0" />
                                
                                <!-- Steps -->
                                <VerticalStackLayout Grid.Column="0" Spacing="12">
                                    <Border x:Name="Step1Border" BackgroundColor="#10B981" StrokeShape="RoundRectangle 28" HeightRequest="56" WidthRequest="56" HorizontalOptions="Center" StrokeThickness="0">
                                        <Path Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14H7v-2h5v2zm3-4H7v-2h8v2zm0-4H7V7h8v2z" Fill="White" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Label Text="Order Placed" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" />
                                    <Label x:Name="OrderDateLabel" Text="--" FontSize="11" TextColor="#64748B" HorizontalOptions="Center" />
                                </VerticalStackLayout>
    
                                <VerticalStackLayout Grid.Column="1" Spacing="12">
                                    <Border x:Name="Step2Border" BackgroundColor="#10B981" StrokeShape="RoundRectangle 28" HeightRequest="56" WidthRequest="56" HorizontalOptions="Center" StrokeThickness="0">
                                        <Path Data="M21 18v1c0 1.1-.9 2-2 2H5c-1.1 0-2-.9-2-2V5c0-1.1.9-2 2-2h14c1.1 0 2 .9 2 2v1h-9c-1.1 0-2 .9-2 2v8c0 1.1.9 2 2 2h9zm-9-10v8h10V8H12zm4 5.5c-.83 0-1.5-.67-1.5-1.5s.67-1.5 1.5-1.5 1.5.67 1.5 1.5-.67 1.5-1.5 1.5z" Fill="White" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Label Text="Paid" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" />
                                </VerticalStackLayout>
    
                                <VerticalStackLayout Grid.Column="2" Spacing="12">
                                    <Border x:Name="Step3Border" BackgroundColor="#F1F5F9" StrokeShape="RoundRectangle 28" HeightRequest="56" WidthRequest="56" HorizontalOptions="Center" StrokeThickness="0">
                                        <Path Data="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zm-14 9c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm13 0c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z" Fill="#94A3B8" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Label Text="Shipped" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" />
                                </VerticalStackLayout>
    
                                <VerticalStackLayout Grid.Column="3" Spacing="12">
                                    <Border x:Name="Step4Border" BackgroundColor="#F1F5F9" StrokeShape="RoundRectangle 28" HeightRequest="56" WidthRequest="56" HorizontalOptions="Center" StrokeThickness="0">
                                        <Path Data="M20 6h-2.18c.11-.31.18-.65.18-1 0-1.66-1.34-3-3-3-1.05 0-1.96.54-2.5 1.35l-.5.65-.5-.65C10.96 2.54 10.05 2 9 2 7.34 2 6 3.34 6 5c0 .35.07.69.18 1H4c-1.11 0-1.99.89-1.99 2L2 19c0 1.11.89 2 2 2h16c1.11 0 2-.89 2-2V8c0-1.11-.89-2-2-2zm-5-2c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zM9 4c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm11 15H4v-2h16v2zm0-5H4V8h5.08L7 10.83 8.41 12.25 12 8.66l3.59 3.59L17 10.83 14.92 8H20v6z" Fill="#94A3B8" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Label Text="Delivering" FontSize="12" FontAttributes="Bold" HorizontalOptions="Center" />
                                </VerticalStackLayout>
    
                                <VerticalStackLayout Grid.Column="4" Spacing="12">
                                    <Border x:Name="Step5Border" BackgroundColor="#F1F5F9" StrokeShape="RoundRectangle 28" HeightRequest="56" WidthRequest="56" HorizontalOptions="Center" StrokeThickness="0">
                                        <Path Data="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" Fill="#94A3B8" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Label Text="Arrived" FontSize="12" TextColor="#94A3B8" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Grid>
    
                            <!-- Status Message -->
                            <Border BackgroundColor="#F0FDF4" StrokeShape="RoundRectangle 16" Padding="20" StrokeThickness="0">
                                <HorizontalStackLayout Spacing="16">
                                    <Path Data="M20 8h-3V4H3c-1.1 0-2 .9-2 2v11h2c0 1.66 1.34 3 3 3s3-1.34 3-3h6c0 1.66 1.34 3 3 3s3-1.34 3-3h2v-5l-3-4zm-14 9c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1zm13 0c-.55 0-1-.45-1-1s.45-1 1-1 1 .45 1 1-.45 1-1 1z" Fill="#10B981" HeightRequest="24" WidthRequest="24" VerticalOptions="Center" />
                                    <VerticalStackLayout Spacing="4">
                                        <Label x:Name="CurrentStatusLabel" Text="Order is being processed" FontSize="16" FontAttributes="Bold" TextColor="#15803D" />
                                        <Label x:Name="StatusDetailLabel" Text="Your order has been received and is waiting for validation." FontSize="14" TextColor="#15803D" />
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </Border>
    
                    <Grid ColumnDefinitions="*,2*" ColumnSpacing="32">
                        <!-- Delivery Address -->
                        <Border Grid.Column="0" BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="32" StrokeThickness="0" VerticalOptions="Start">
                            <VerticalStackLayout Spacing="24">
                                <Label Text="Delivery Details" FontSize="18" FontAttributes="Bold" TextColor="#463366" />
                                <VerticalStackLayout Spacing="8">
                                    <Label x:Name="CustomerNameLabel" Text="--" FontSize="16" FontAttributes="Bold" TextColor="#1E293B" />
                                    <Label x:Name="OrderItemsLabel" Text="--" FontSize="14" TextColor="#64748B" />
                                    <Label x:Name="OrderAmountLabel" Text="--" FontSize="14" TextColor="#64748B" />
                                    <Label x:Name="DriverLabel" Text="Driver: Pending" FontSize="14" TextColor="#624890" FontAttributes="Italic" Margin="0,10,0,0"/>
                                    <Label x:Name="ETALabel" Text="ETA: Pending" FontSize="14" TextColor="#10B981" FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
    
                        <!-- Parcel Journey -->
                        <Border Grid.Column="1" BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="32" StrokeThickness="0">
                            <VerticalStackLayout Spacing="24">
                                <Label Text="Parcel Journey" FontSize="18" FontAttributes="Bold" TextColor="#463366" />
                                
                                <VerticalStackLayout Spacing="16">
                                    <!-- Journey Items -->
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                                        <Ellipse WidthRequest="12" HeightRequest="12" Fill="#10B981" VerticalOptions="Start" Margin="0,10,0,0"/>
                                        <Border BackgroundColor="#F0FDF4" StrokeShape="RoundRectangle 12" Padding="16" StrokeThickness="0">
                                            <VerticalStackLayout Spacing="4">
                                                <Label Text="System Status Update" FontSize="14" FontAttributes="Bold" TextColor="#15803D" />
                                                <Label Text="Order confirmed and queued for processing." FontSize="13" TextColor="#15803D" />
                                            </VerticalStackLayout>
                                        </Border>
                                    </Grid>
    
                                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                                        <Ellipse WidthRequest="12" HeightRequest="12" Fill="#CBD5E1" VerticalOptions="Center"/>
                                        <HorizontalStackLayout Grid.Column="1" Spacing="12">
                                            <Label Text="Latest" FontSize="13" TextColor="#64748B" WidthRequest="120" />
                                            <Label x:Name="CurrentLocationLabel" Text="Preparing items for shipment..." FontSize="13" TextColor="#1E293B" />
                                        </HorizontalStackLayout>
                                    </Grid>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
