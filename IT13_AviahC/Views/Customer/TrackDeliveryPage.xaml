<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:IT13_AviahC.Views.Customer.Components"
             x:Class="IT13_AviahC.Views.Customer.TrackDeliveryPage"
             BackgroundColor="#F8FAFC"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <!-- Modern Header -->
        <components:CustomerHeaderView Grid.Row="0" ActiveTab="Track" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="30" Spacing="25">
                <!-- Status Banner -->
                <Border BackgroundColor="#6366F1" StrokeShape="RoundRectangle 20" Padding="25" StrokeThickness="0">
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Live Tracking" TextColor="#E0E7FF" FontSize="12" FontAttributes="Bold" CharacterSpacing="1" />
                            <Label x:Name="OrderRefLabel" Text="Loading Order..." TextColor="White" FontSize="24" FontAttributes="Bold" />
                            <Label x:Name="OrderDateLabel" Text="--" TextColor="#C7D2FE" FontSize="13" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1" BackgroundColor="#4F46E5" StrokeShape="RoundRectangle 12" Padding="15,8" VerticalOptions="Center">
                            <Label Text="Active" TextColor="White" FontSize="12" FontAttributes="Bold" />
                        </Border>
                    </Grid>
                </Border>

                <!-- Empty State -->
                <VerticalStackLayout x:Name="EmptyStateView" IsVisible="False" Spacing="20" Padding="40" HorizontalOptions="Center">
                    <Label Text="📦" FontSize="60" HorizontalOptions="Center" />
                    <Label Text="No active deliveries" FontSize="18" FontAttributes="Bold" TextColor="#1E293B" HorizontalOptions="Center" />
                    <Label Text="Orders will appear here once they are shipped." TextColor="#64748B" HorizontalOptions="Center" HorizontalTextAlignment="Center" />
                </VerticalStackLayout>

                <!-- Main Tracking Content -->
                <Grid x:Name="TrackingContent" RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" ColumnSpacing="20" RowSpacing="20">
                    
                    <!-- Progress Timeline (Spans both columns) -->
                    <Border Grid.Row="0" Grid.ColumnSpan="2" BackgroundColor="White" StrokeShape="RoundRectangle 20" Padding="25" StrokeThickness="0">
                        <VerticalStackLayout Spacing="25">
                            <Label Text="Delivery Progress" FontSize="16" FontAttributes="Bold" TextColor="#1E293B" />
                            
                            <Grid ColumnDefinitions="*,*,*,*" HorizontalOptions="Fill">
                                <BoxView Grid.ColumnSpan="4" HeightRequest="4" BackgroundColor="#F1F5F9" VerticalOptions="Center" Margin="30,0" />
                                
                                <!-- Step 1 -->
                                <VerticalStackLayout Grid.Column="0" Spacing="8">
                                    <Ellipse x:Name="Step1Dot" WidthRequest="20" HeightRequest="20" Fill="#6366F1" HorizontalOptions="Center" />
                                    <Label Text="Order" FontSize="11" TextColor="#64748B" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                                <!-- Step 2 -->
                                <VerticalStackLayout Grid.Column="1" Spacing="8">
                                    <Ellipse x:Name="Step2Dot" WidthRequest="20" HeightRequest="20" Fill="#E2E8F0" HorizontalOptions="Center" />
                                    <Label Text="Paid" FontSize="11" TextColor="#64748B" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                                <!-- Step 3 -->
                                <VerticalStackLayout Grid.Column="2" Spacing="8">
                                    <Ellipse x:Name="Step3Dot" WidthRequest="20" HeightRequest="20" Fill="#E2E8F0" HorizontalOptions="Center" />
                                    <Label Text="Shipping" FontSize="11" TextColor="#64748B" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                                <!-- Step 4 -->
                                <VerticalStackLayout Grid.Column="3" Spacing="8">
                                    <Ellipse x:Name="Step4Dot" WidthRequest="20" HeightRequest="20" Fill="#E2E8F0" HorizontalOptions="Center" />
                                    <Label Text="Arrived" FontSize="11" TextColor="#64748B" HorizontalOptions="Center" />
                                </VerticalStackLayout>
                            </Grid>

                            <Border BackgroundColor="#F8FAFC" Padding="15" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                                <Label x:Name="CurrentStatusLabel" Text="Waiting for status..." FontSize="14" TextColor="#475569" HorizontalTextAlignment="Center" />
                            </Border>

                            <!-- Feedback Trigger Button (Visible only when Completed) -->
                            <Button x:Name="FeedbackPromptButton" Text="⭐ Rate our Service" IsVisible="False" BackgroundColor="#6366F1" TextColor="White" CornerRadius="12" HeightRequest="45" FontAttributes="Bold" Clicked="OnShowFeedbackModalClicked" />
                        </VerticalStackLayout>
                    </Border>

                    <!-- Details Card -->
                    <Border Grid.Row="1" Grid.Column="0" BackgroundColor="White" StrokeShape="RoundRectangle 20" Padding="20" StrokeThickness="0">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="Delivery Info" FontSize="15" FontAttributes="Bold" TextColor="#1E293B" />
                            <VerticalStackLayout Spacing="10">
                                <Label x:Name="CustomerNameLabel" Text="--" FontSize="14" TextColor="#334155" />
                                <Label x:Name="DriverLabel" Text="Driver: --" FontSize="13" TextColor="#64748B" />
                                <Label x:Name="ETALabel" Text="ETA: --" FontSize="13" FontAttributes="Bold" TextColor="#4F46E5" />
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Location Card -->
                    <Border Grid.Row="1" Grid.Column="1" BackgroundColor="White" StrokeShape="RoundRectangle 20" Padding="20" StrokeThickness="0">
                        <VerticalStackLayout Spacing="15">
                            <Label Text="Parcel Journey" FontSize="15" FontAttributes="Bold" TextColor="#1E293B" />
                            <CollectionView x:Name="JourneyCollection">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="30,*" Padding="0,0,0,15">
                                            <!-- Timeline Line and Dot -->
                                            <BoxView Grid.RowSpan="2" WidthRequest="1" BackgroundColor="#E2E8F0" HorizontalOptions="Center" VerticalOptions="Fill" Margin="0,5,0,0" />
                                            
                                            <Ellipse x:Name="TimelineDot" WidthRequest="10" HeightRequest="10" Fill="#CBD5E1" HorizontalOptions="Center" VerticalOptions="Start" Margin="0,5,0,0">
                                                <Ellipse.Triggers>
                                                    <DataTrigger TargetType="Ellipse" Binding="{Binding IsLatest}" Value="True">
                                                        <Setter Property="Fill" Value="#22C55E" />
                                                        <Setter Property="WidthRequest" Value="12" />
                                                        <Setter Property="HeightRequest" Value="12" />
                                                    </DataTrigger>
                                                </Ellipse.Triggers>
                                            </Ellipse>
                                            
                                            <Border Grid.Column="1" Padding="12" StrokeThickness="0" BackgroundColor="Transparent">
                                                <Border.Triggers>
                                                    <DataTrigger TargetType="Border" Binding="{Binding IsLatest}" Value="True">
                                                        <Setter Property="BackgroundColor" Value="#F0FDF4" />
                                                        <Setter Property="StrokeShape" Value="RoundRectangle 12" />
                                                    </DataTrigger>
                                                </Border.Triggers>
                                                <VerticalStackLayout Spacing="2">
                                                    <HorizontalStackLayout Spacing="8">
                                                        <Label Text="{Binding FormattedTime}" FontSize="11" TextColor="#94A3B8" VerticalOptions="Center" />
                                                        <Label Text="{Binding Status}" FontSize="12" FontAttributes="Bold" TextColor="#1E293B" VerticalOptions="Center">
                                                            <Label.Triggers>
                                                                <DataTrigger TargetType="Label" Binding="{Binding IsLatest}" Value="True">
                                                                    <Setter Property="TextColor" Value="#166534" />
                                                                </DataTrigger>
                                                            </Label.Triggers>
                                                        </Label>
                                                    </HorizontalStackLayout>
                                                    <Label Text="{Binding Location}" FontSize="11" TextColor="#64748B" Margin="0,2,0,0">
                                                        <Label.Triggers>
                                                            <DataTrigger TargetType="Label" Binding="{Binding IsLatest}" Value="True">
                                                                    <Setter Property="TextColor" Value="#15803D" />
                                                            </DataTrigger>
                                                        </Label.Triggers>
                                                    </Label>
                                                </VerticalStackLayout>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>

                </Grid>
            </VerticalStackLayout>
        </ScrollView>

        <!-- Feedback Modal Overlay -->
        <Grid x:Name="FeedbackModalOverlay" Grid.RowSpan="2" BackgroundColor="#80000000" IsVisible="False">
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="30" WidthRequest="450" HorizontalOptions="Center" VerticalOptions="Center" StrokeThickness="0">
                <VerticalStackLayout Spacing="20">
                    <Label Text="How was your delivery?" FontSize="22" FontAttributes="Bold" TextColor="#1E293B" HorizontalTextAlignment="Center" />
                    <Label Text="We're glad your parcel arrived! Please share your thoughts with us." FontSize="14" TextColor="#64748B" HorizontalTextAlignment="Center" />
                    
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Subject" FontSize="12" FontAttributes="Bold" TextColor="#64748B" />
                        <Border BackgroundColor="#F8FAFC" Padding="15" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                            <Entry x:Name="FeedbackSubjectEntry" Placeholder="e.g. Excellent Service" TextColor="#1E293B" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Message" FontSize="12" FontAttributes="Bold" TextColor="#64748B" />
                        <Border BackgroundColor="#F8FAFC" Padding="15" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                            <Editor x:Name="FeedbackMessageEditor" Placeholder="Your comments..." HeightRequest="100" TextColor="#1E293B" />
                        </Border>
                    </VerticalStackLayout>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                        <Button Text="Later" Clicked="OnCloseFeedbackModalClicked" BackgroundColor="#F1F5F9" TextColor="#64748B" HeightRequest="50" CornerRadius="12" />
                        <Button Grid.Column="1" Text="Submit" Clicked="OnSubmitModalFeedbackClicked" BackgroundColor="#6366F1" TextColor="White" HeightRequest="50" CornerRadius="12" FontAttributes="Bold" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
