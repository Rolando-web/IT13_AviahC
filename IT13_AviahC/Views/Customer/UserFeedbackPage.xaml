<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:IT13_AviahC.Views.Customer.Components"
             x:Class="IT13_AviahC.Views.Customer.UserFeedbackPage"
             BackgroundColor="#F8FAFC"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <components:CustomerHeaderView Grid.Row="0" ActiveTab="Feedback" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="40" Spacing="32">
                <!-- Feedback History List -->
                <VerticalStackLayout Spacing="24">
                    <Label Text="My Feedback History" FontSize="24" FontAttributes="Bold" TextColor="#463366" />
                    
                    <CollectionView x:Name="FeedbackHistoryCollection">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border BackgroundColor="White" StrokeShape="RoundRectangle 20" Padding="24" Margin="0,0,0,16" StrokeThickness="0">
                                    <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="12">
                                        <VerticalStackLayout Spacing="4">
                                            <HorizontalStackLayout Spacing="8">
                                                <Label Text="📅" FontSize="14" VerticalOptions="Center" />
                                                <Label Text="{Binding DateSubmitted, StringFormat='{0:MMM dd, yyyy}'}" FontSize="18" FontAttributes="Bold" TextColor="#463366" VerticalOptions="Center" />
                                                <Label Text="•" FontSize="18" TextColor="#94A3B8" VerticalOptions="Center" Margin="4,0" />
                                                <Label Text="{Binding OrderRef}" FontSize="14" FontAttributes="Bold" TextColor="#624890" VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                            <Label Text="Verified Customer Review" FontSize="13" TextColor="#64748B" />
                                        </VerticalStackLayout>

                                        <Border Grid.Column="1" BackgroundColor="#F0FDF4" StrokeShape="RoundRectangle 8" Padding="12,4" StrokeThickness="0" VerticalOptions="Center">
                                            <Label Text="SUBMITTED" TextColor="#166534" FontSize="11" FontAttributes="Bold" />
                                        </Border>

                                        <BoxView Grid.Row="1" Grid.ColumnSpan="2" HeightRequest="1" BackgroundColor="#F1F5F9" Margin="0,4" />

                                        <Label Grid.Row="1" Grid.ColumnSpan="2" Text="{Binding Comments}" FontSize="15" TextColor="#475569" LineBreakMode="WordWrap" Margin="0,12,0,0" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>

                    <!-- Empty State -->
                    <VerticalStackLayout x:Name="EmptyHistoryView" IsVisible="False" Spacing="20" Padding="60" HorizontalOptions="Center">
                        <Border BackgroundColor="#F3F0FA" StrokeShape="RoundRectangle 50" HeightRequest="100" WidthRequest="100" StrokeThickness="0" HorizontalOptions="Center">
                            <Label Text="📝" FontSize="40" HorizontalOptions="Center" VerticalOptions="Center" />
                        </Border>
                        <Label Text="No Feedback Found" FontSize="20" FontAttributes="Bold" TextColor="#463366" HorizontalTextAlignment="Center" />
                        <Label Text="You haven't submitted any feedback yet. Complete an order to share your experience!" 
                               FontSize="14" TextColor="#64748B" HorizontalTextAlignment="Center" MaxLines="2" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
