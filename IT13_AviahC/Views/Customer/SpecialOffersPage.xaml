<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:IT13_AviahC.Views.Customer.Components"
             x:Class="IT13_AviahC.Views.Customer.SpecialOffersPage"
             BackgroundColor="#F8FAFC"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <components:CustomerHeaderView Grid.Row="0" ActiveTab="Offers" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="30" Spacing="30">
                
                <!-- Premium Hero Section -->
                <Border BackgroundColor="#1E293B" StrokeShape="RoundRectangle 30" Padding="40" StrokeThickness="0">
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                        <VerticalStackLayout Spacing="15" VerticalOptions="Center">
                            <Border BackgroundColor="#FACC15" Padding="12,5" HorizontalOptions="Start" StrokeShape="RoundRectangle 8" StrokeThickness="0">
                                <Label Text="SEASONAL SALE" TextColor="#1E293B" FontAttributes="Bold" FontSize="11" CharacterSpacing="1" />
                            </Border>
                            <Label Text="Exclusive Offers" TextColor="White" FontSize="42" FontAttributes="Bold" />
                            <Label Text="Premium fashion pieces at unbeatable prices. Once they're gone, they're gone!" TextColor="#94A3B8" FontSize="16" />
                        </VerticalStackLayout>
                        
                        <Image Grid.Column="1" Source="dress.png" HeightRequest="200" HorizontalOptions="End">
                            <Image.Shadow>
                                <Shadow Brush="Black" Offset="0,10" Radius="20" Opacity="0.3" />
                            </Image.Shadow>
                        </Image>
                    </Grid>
                </Border>

                <!-- Grid Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="5">
                        <Label Text="Hot Deals" FontSize="24" FontAttributes="Bold" TextColor="#1E293B" />
                        <Label Text="Selected items currently on promotion" TextColor="#64748B" FontSize="14" />
                    </VerticalStackLayout>
                </Grid>

                <!-- Empty State -->
                <VerticalStackLayout x:Name="EmptyStateView" IsVisible="False" Spacing="20" Padding="40" HorizontalOptions="Center">
                    <Label Text="🏷️" FontSize="60" HorizontalOptions="Center" />
                    <Label Text="No active offers right now" FontSize="18" FontAttributes="Bold" TextColor="#1E293B" HorizontalOptions="Center" />
                    <Label Text="Check back later for exclusive discounts." TextColor="#64748B" HorizontalOptions="Center" />
                </VerticalStackLayout>

                <!-- Product Grid -->
                <CollectionView x:Name="OffersCollection" SelectionMode="None">
                    <CollectionView.ItemsLayout>
                        <GridItemsLayout Orientation="Vertical" Span="4" HorizontalItemSpacing="20" VerticalItemSpacing="20" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White" StrokeShape="RoundRectangle 20" StrokeThickness="0" HeightRequest="380">
                                <Border.Shadow>
                                    <Shadow Brush="#CBD5E1" Offset="0,4" Radius="10" Opacity="0.2" />
                                </Border.Shadow>
                                
                                <Grid RowDefinitions="*,Auto">
                                    <!-- Product Image Area -->
                                    <Border Grid.Row="0" StrokeShape="RoundRectangle 20,20,0,0" StrokeThickness="0" BackgroundColor="#F1F5F9">
                                        <Grid>
                                            <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                            
                                            <!-- Sale Badge -->
                                            <Border Margin="15" VerticalOptions="Start" HorizontalOptions="Start" BackgroundColor="#EF4444" Padding="12,6" StrokeShape="RoundRectangle 8" StrokeThickness="0">
                                                <Label Text="SALE" TextColor="White" FontSize="11" FontAttributes="Bold" />
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <!-- Content Area -->
                                    <VerticalStackLayout Grid.Row="1" Padding="20" Spacing="10">
                                        <Label Text="{Binding Category}" FontSize="12" TextColor="#6366F1" FontAttributes="Bold" />
                                        <Label Text="{Binding ProductName}" FontSize="16" FontAttributes="Bold" TextColor="#1E293B" MaxLines="1" LineBreakMode="TailTruncation" />
                                        
                                        <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                                            <Label Text="{Binding DiscountedPriceText}" FontSize="18" FontAttributes="Bold" TextColor="#EF4444" />
                                            <Label Text="{Binding FormattedPrice}" FontSize="14" TextColor="#94A3B8" TextDecorations="Strikethrough" VerticalOptions="Center" />
                                        </HorizontalStackLayout>

                                        <Button Text="Order Now" 
                                                Clicked="OnOrderClicked"
                                                CommandParameter="{Binding .}"
                                                BackgroundColor="#1E293B" 
                                                TextColor="White" 
                                                HeightRequest="45" 
                                                CornerRadius="12" 
                                                FontAttributes="Bold"
                                                Margin="0,5,0,0" />
                                    </VerticalStackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>

            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
