<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:IT13_AviahC.Views.Customer.Components"
             x:Class="IT13_AviahC.Views.Customer.SpecialOffersPage"
             BackgroundColor="#F8FAFC"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0">
            <components:CustomerHeaderView ActiveTab="Offers" />

            <VerticalStackLayout Padding="40" Spacing="32">

                <!-- Promo Banner -->
                <Border BackgroundColor="#DC2626" StrokeShape="RoundRectangle 24" Padding="32" StrokeThickness="0">
                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="20">
                        <VerticalStackLayout Spacing="8" VerticalOptions="Center">
                            <HorizontalStackLayout Spacing="12">
                                <Label Text="🔥" FontSize="20" VerticalOptions="Center"/>
                                <Label Text="Hot Deals &amp; Special Offers" TextColor="White" FontSize="22" FontAttributes="Bold" VerticalOptions="Center"/>
                            </HorizontalStackLayout>
                            <Label Text="Limited-time discounts on our best-selling items. Don't miss out!" TextColor="#FEE2E2" FontSize="14" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1" BackgroundColor="White" StrokeShape="RoundRectangle 20" Padding="20,10" StrokeThickness="0" VerticalOptions="Center">
                            <Label Text="Shop All Deals" TextColor="#DC2626" FontAttributes="Bold" FontSize="14"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Section Header -->
                <Label Text="Discounted Items" FontSize="22" FontAttributes="Bold" TextColor="#1E293B"/>

                <!-- Empty State -->
                <VerticalStackLayout x:Name="EmptyPromotionsView" Spacing="16" Padding="60" HorizontalOptions="Center" IsVisible="False">
                    <Border BackgroundColor="#FEF2F2" StrokeShape="RoundRectangle 50" HeightRequest="100" WidthRequest="100" StrokeThickness="0" HorizontalOptions="Center">
                        <Label Text="🏷️" FontSize="40" HorizontalOptions="Center" VerticalOptions="Center"/>
                    </Border>
                    <Label Text="No Active Promotions" FontSize="20" FontAttributes="Bold" TextColor="#1E293B" HorizontalTextAlignment="Center" />
                    <Label Text="Check back later for exclusive deals and seasonal sales!" FontSize="14" TextColor="#64748B" HorizontalTextAlignment="Center" MaxWidthRequest="350"/>
                </VerticalStackLayout>

                <!-- Offers Grid -->
                <FlexLayout x:Name="OffersCollection" Wrap="Wrap" JustifyContent="Start" AlignContent="Start">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White" StrokeShape="RoundRectangle 16" StrokeThickness="1" Stroke="#E2E8F0" WidthRequest="240" Margin="0,0,20,20">
                                <VerticalStackLayout>
                                    <!-- Image with Discount Badge -->
                                    <Grid>
                                        <Border BackgroundColor="#F1F5F9" StrokeShape="RoundRectangle 16,16,0,0" HeightRequest="200" StrokeThickness="0">
                                            <Image Source="{Binding ImageUrl}" Aspect="AspectFill" HorizontalOptions="Fill" VerticalOptions="Fill"/>
                                        </Border>
                                        <!-- Badges -->
                                        <HorizontalStackLayout Spacing="6" Margin="12" VerticalOptions="Start" HorizontalOptions="Start">
                                            <Border BackgroundColor="#DC2626" StrokeShape="RoundRectangle 6" Padding="8,4" StrokeThickness="0">
                                                <Label Text="{Binding DiscountPercent}" TextColor="White" FontSize="11" FontAttributes="Bold"/>
                                            </Border>
                                            <Border BackgroundColor="#7C3AED" StrokeShape="RoundRectangle 6" Padding="8,4" StrokeThickness="0">
                                                <Label Text="{Binding PromotionName}" TextColor="White" FontSize="11" FontAttributes="Bold"/>
                                            </Border>
                                        </HorizontalStackLayout>
                                    </Grid>

                                    <!-- Info -->
                                    <VerticalStackLayout Padding="16" Spacing="8">
                                        <Label Text="{Binding ItemName}" FontSize="15" FontAttributes="Bold" TextColor="#1E293B" MaxLines="1" LineBreakMode="TailTruncation"/>
                                        
                                        <HorizontalStackLayout Spacing="10">
                                            <Label Text="{Binding PromoPrice}" FontSize="16" TextColor="#DC2626" FontAttributes="Bold"/>
                                            <Label Text="{Binding OriginalPrice}" FontSize="13" TextColor="#94A3B8" TextDecorations="Strikethrough" VerticalOptions="Center"/>
                                        </HorizontalStackLayout>
                                        
                                        <Border BackgroundColor="#FEF2F2" StrokeShape="RoundRectangle 8" Padding="10,6" StrokeThickness="0">
                                            <Label Text="{Binding Savings}" FontSize="12" TextColor="#DC2626" FontAttributes="Bold"/>
                                        </Border>
                                    </VerticalStackLayout>
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </FlexLayout>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
