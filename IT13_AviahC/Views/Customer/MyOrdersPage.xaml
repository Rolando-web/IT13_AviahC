<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:IT13_AviahC.Views.Customer.Components"
             xmlns:models="clr-namespace:IT13_AviahC.Models"
             x:Class="IT13_AviahC.Views.Customer.MyOrdersPage"
             BackgroundColor="#F8FAFC"
             Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <components:CustomerHeaderView Grid.Row="0" ActiveTab="Orders" />

        <ScrollView Grid.Row="1">
            <VerticalStackLayout Padding="40" Spacing="32">
                <Label Text="My Order History" FontSize="24" FontAttributes="Bold" TextColor="#463366" />

                <!-- Empty State -->
                <VerticalStackLayout x:Name="EmptyOrdersView" Spacing="20" Padding="60" HorizontalOptions="Center" IsVisible="False">
                    <Border BackgroundColor="#F3F0FA" StrokeShape="RoundRectangle 50" HeightRequest="100" WidthRequest="100" StrokeThickness="0" HorizontalOptions="Center">
                        <Path Data="M19 3h-4.18C14.4 1.84 13.3 1 12 1s-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm7 16H5V5h2v2h10V5h2v14z" 
                              Fill="#624890" HeightRequest="40" WidthRequest="40" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Label Text="No Orders Yet" FontSize="20" FontAttributes="Bold" TextColor="#463366" HorizontalTextAlignment="Center" />
                    <Label Text="Looks like you haven't placed any orders yet. Visit our boutique to start shopping!" 
                           FontSize="14" TextColor="#64748B" HorizontalTextAlignment="Center" MaxLines="2" />
                    <Button Text="Go to Boutique" BackgroundColor="#624890" TextColor="White" CornerRadius="12" 
                            Padding="24,0" HeightRequest="44" FontAttributes="Bold" Clicked="OnShopClicked" Margin="0,10,0,0" />
                </VerticalStackLayout>

                <!-- Orders Collection -->
                <CollectionView x:Name="OrdersCollection" IsVisible="True">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="16" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate x:DataType="models:OrderItem">
                            <Border BackgroundColor="White" StrokeShape="RoundRectangle 20" Padding="24" StrokeThickness="0">
                                <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto" RowSpacing="12">
                                    <VerticalStackLayout Spacing="4">
                                        <Label Text="{Binding OrderRef}" FontAttributes="Bold" FontSize="18" TextColor="#463366" />
                                        <Label Text="{Binding OrderDateAndSummary}" FontSize="13" TextColor="#64748B" />
                                    </VerticalStackLayout>

                                    <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" VerticalOptions="Center">
                                        <Border BackgroundColor="{Binding StatusColor}" StrokeShape="RoundRectangle 8" Padding="12,4" StrokeThickness="0">
                                            <Label Text="{Binding Status}" TextColor="White" FontSize="11" FontAttributes="Bold" />
                                        </Border>
                                    </VerticalStackLayout>

                                    <BoxView Grid.Row="1" Grid.ColumnSpan="2" HeightRequest="1" BackgroundColor="#F1F5F9" Margin="0,4" />

                                    <Grid Grid.Row="1" Grid.ColumnSpan="2" ColumnDefinitions="*,Auto" Margin="0,12,0,0">
                                        <VerticalStackLayout Spacing="2">
                                            <Label Text="Total Amount" FontSize="11" TextColor="#94A3B8" FontAttributes="Bold" CharacterSpacing="1" />
                                            <Label Text="{Binding FormattedTotal}" FontSize="18" FontAttributes="Bold" TextColor="#624890" />
                                        </VerticalStackLayout>
                                        <Button Grid.Column="1" Text="Track Order" BackgroundColor="#F3F0FA" TextColor="#624890" 
                                                CornerRadius="10" Padding="16,0" HeightRequest="36" FontSize="12" FontAttributes="Bold" 
                                                IsVisible="{Binding IsTrackable}" Clicked="OnTrackClicked" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
