<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:IT13_AviahC.Views.Customer.Components"
             x:Class="IT13_AviahC.Views.Customer.MyOrdersPage"
             BackgroundColor="#F8FAFC"
             Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Spacing="0">
            <components:CustomerHeaderView ActiveTab="Orders" />

            <VerticalStackLayout Padding="40" Spacing="32">

                <!-- Header -->
                <Grid ColumnDefinitions="*,Auto">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="Purchase History" FontSize="22" FontAttributes="Bold" TextColor="#1E293B"/>
                        <Label Text="View and track all your past orders" FontSize="14" TextColor="#64748B"/>
                    </VerticalStackLayout>
                </Grid>

                <!-- Empty State -->
                <VerticalStackLayout x:Name="EmptyOrdersView" Spacing="16" Padding="60" HorizontalOptions="Center" IsVisible="False">
                    <Border BackgroundColor="#F5F3FF" StrokeShape="RoundRectangle 50" HeightRequest="100" WidthRequest="100" StrokeThickness="0" HorizontalOptions="Center">
                        <Path Data="M19 3h-4.18C14.4 1.84 13.3 1 12 1c-1.3 0-2.4.84-2.82 2H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 0c.55 0 1 .45 1 1s-.45 1-1 1-1-.45-1-1 .45-1 1-1zm2 14H7v-2h7v2zm3-4H7v-2h10v2zm0-4H7V7h10v2z" 
                              Fill="#7C3AED" HeightRequest="40" WidthRequest="40" HorizontalOptions="Center" VerticalOptions="Center" />
                    </Border>
                    <Label Text="No Orders Yet" FontSize="20" FontAttributes="Bold" TextColor="#1E293B" HorizontalTextAlignment="Center" />
                    <Label Text="You haven't placed any orders yet. Explore our boutique to find something you love!" FontSize="14" TextColor="#64748B" HorizontalTextAlignment="Center" MaxWidthRequest="350" />
                    <Button Text="Start Shopping" BackgroundColor="#624890" TextColor="White" CornerRadius="12" Padding="32,14" FontAttributes="Bold" HorizontalOptions="Center" Clicked="OnShopClicked"/>
                </VerticalStackLayout>

                <!-- Orders List -->
                <VerticalStackLayout x:Name="OrdersCollection" Spacing="12">
                    <BindableLayout.ItemTemplate>
                        <DataTemplate>
                            <Border BackgroundColor="White" StrokeShape="RoundRectangle 16" Padding="20" StrokeThickness="1" Stroke="#E2E8F0">
                                <Grid ColumnDefinitions="Auto,*,Auto,Auto" ColumnSpacing="16">
                                    <!-- Icon -->
                                    <Border BackgroundColor="#F5F3FF" StrokeShape="RoundRectangle 12" HeightRequest="48" WidthRequest="48" StrokeThickness="0">
                                        <Path Data="M19 7h-3V6c0-1.1-.9-2-2-2h-4c-1.1 0-2 .9-2 2v1H5c-1.1 0-2 .9-2 2v11c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V9c0-1.1-.9-2-2-2zm-5-1v1h-4V6h4z" 
                                              Fill="#7C3AED" HorizontalOptions="Center" VerticalOptions="Center" HeightRequest="22" WidthRequest="22"/>
                                    </Border>

                                    <!-- Order Info -->
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="4">
                                        <Label Text="{Binding OrderRef}" FontSize="15" FontAttributes="Bold" TextColor="#1E293B"/>
                                        <Label Text="{Binding OrderDateAndSummary}" FontSize="12" TextColor="#64748B"/>
                                    </VerticalStackLayout>

                                    <!-- Price & Status -->
                                    <VerticalStackLayout Grid.Column="2" HorizontalOptions="End" VerticalOptions="Center" Spacing="4">
                                        <Label Text="{Binding FormattedTotal}" FontSize="15" FontAttributes="Bold" TextColor="#1E293B" HorizontalTextAlignment="End"/>
                                        <Border BackgroundColor="{Binding StatusColor}" StrokeShape="RoundRectangle 8" Padding="10,3" StrokeThickness="0" HorizontalOptions="End" Opacity="0.15">
                                            <Label Text="{Binding Status}" FontSize="11" TextColor="{Binding StatusColor}" FontAttributes="Bold"/>
                                        </Border>
                                    </VerticalStackLayout>

                                    <!-- Track Button -->
                                    <Button Grid.Column="3" 
                                            Text="Track" 
                                            IsVisible="{Binding IsTrackable}" 
                                            BackgroundColor="#F5F3FF" 
                                            TextColor="#7C3AED" 
                                            FontSize="12" 
                                            FontAttributes="Bold" 
                                            CornerRadius="8"
                                            Padding="16,8"
                                            VerticalOptions="Center"
                                            Clicked="OnTrackClicked" 
                                            CommandParameter="{Binding OrderRef}"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </BindableLayout.ItemTemplate>
                </VerticalStackLayout>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
