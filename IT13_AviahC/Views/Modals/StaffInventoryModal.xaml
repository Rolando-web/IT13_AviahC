<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IT13_AviahC.Views.Modals.StaffInventoryModal">
    <Grid BackgroundColor="#80000000">
        <Border BackgroundColor="White"
                StrokeShape="RoundRectangle 24"
                VerticalOptions="Center"
                HorizontalOptions="Center"
                WidthRequest="500"
                Padding="40"
                StrokeThickness="0">
            <VerticalStackLayout Spacing="25">
                <Label x:Name="ModalTitle" Text="Add New Product" FontSize="22" FontAttributes="Bold" TextColor="#463366" HorizontalOptions="Center" />
 
                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="20">
                    <VerticalStackLayout Spacing="8">
                        <Border StrokeShape="RoundRectangle 12" HeightRequest="120" WidthRequest="120" BackgroundColor="#F3F0FA" StrokeThickness="0">
                            <Grid>
                                <Label Text="??" FontSize="30" HorizontalOptions="Center" VerticalOptions="Center" />
                                <Image x:Name="ItemImagePreview" Aspect="AspectFill" />
                            </Grid>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnUploadImageClicked" />
                            </Border.GestureRecognizers>
                        </Border>
                        <Label Text="Upload Photo" FontSize="12" TextColor="#624890" HorizontalOptions="Center" TextDecorations="Underline">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnUploadImageClicked" />
                            </Label.GestureRecognizers>
                        </Label>
                    </VerticalStackLayout>
 
                    <VerticalStackLayout Grid.Column="1" Spacing="15">
                        <VerticalStackLayout Spacing="2">
                            <Entry x:Name="ItemNameEntry" Placeholder="Product Name" FontSize="14" TextColor="#1E293B" BackgroundColor="Transparent" />
                            <BoxView HeightRequest="1" BackgroundColor="#3ABEF9" />
                        </VerticalStackLayout>
 
                        <VerticalStackLayout Spacing="2">
                            <Entry x:Name="SKUEntry" Placeholder="SKU" FontSize="14" TextColor="#1E293B" BackgroundColor="Transparent" />
                            <BoxView HeightRequest="1" BackgroundColor="#3ABEF9" />
                        </VerticalStackLayout>
 
                        <VerticalStackLayout Spacing="2">
                            <Picker x:Name="CategoryPicker" Title="Select Category" FontSize="14" TextColor="#1E293B">
                                <Picker.ItemsSource>
                                    <x:Array Type="{x:Type x:String}">
                                        <x:String>Dresses</x:String>
                                        <x:String>Tops</x:String>
                                        <x:String>Bottoms</x:String>
                                        <x:String>Accessories</x:String>
                                    </x:Array>
                                </Picker.ItemsSource>
                            </Picker>
                            <BoxView HeightRequest="1" BackgroundColor="#3ABEF9" />
                        </VerticalStackLayout>
 
                        <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Boutique Stock" FontSize="11" TextColor="#64748B" Margin="2,0,0,0" />
                                <Entry x:Name="QuantityEntry" Placeholder="Boutique Quantity" Keyboard="Numeric" FontSize="14" TextColor="#1E293B" BackgroundColor="Transparent" />
                                <BoxView HeightRequest="1" BackgroundColor="#3ABEF9" />
                            </VerticalStackLayout>
                            <VerticalStackLayout Grid.Column="1" Spacing="2">
                                <Label Text="Warehouse Stock" FontSize="11" TextColor="#64748B" Margin="2,0,0,0" />
                                <Entry x:Name="WarehouseQuantityEntry" Placeholder="Warehouse Quantity" Keyboard="Numeric" FontSize="14" TextColor="#1E293B" BackgroundColor="Transparent" />
                                <BoxView HeightRequest="1" BackgroundColor="#3ABEF9" />
                            </VerticalStackLayout>
                        </Grid>

                        <VerticalStackLayout Spacing="2">
                            <Label Text="Unit Price" FontSize="11" TextColor="#64748B" Margin="2,0,0,0" />
                            <Entry x:Name="PriceEntry" Placeholder="Price" Keyboard="Numeric" FontSize="14" TextColor="#1E293B" BackgroundColor="Transparent" />
                            <BoxView HeightRequest="1" BackgroundColor="#3ABEF9" />
                        </VerticalStackLayout>
 
                        <VerticalStackLayout Spacing="2">
                            <Picker x:Name="PromotionPicker" Title="Apply Promotion (Optional)" FontSize="14" TextColor="#1E293B" ItemDisplayBinding="{Binding PromotionName}" />
                            <BoxView HeightRequest="1" BackgroundColor="#3ABEF9" />
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </Grid>
 
                <Grid ColumnDefinitions="*,*" ColumnSpacing="20" Margin="0,10,0,0">
                    <Label Text="Cancel" TextColor="#64748B" FontSize="16" HorizontalOptions="Center" VerticalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnCloseRequested" />
                        </Label.GestureRecognizers>
                    </Label>
                    <Button Grid.Column="1" Text="Save" BackgroundColor="#624890" TextColor="White" CornerRadius="12" HeightRequest="50" FontSize="16" FontAttributes="Bold" Clicked="OnSaveRequested" />
                </Grid>
            </VerticalStackLayout>
        </Border>
    </Grid>
</ContentView>
