<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="IT13_AviahC.Views.Modals.AdminUserModal"
             BackgroundColor="#80000000">

    <Frame BackgroundColor="White"
           CornerRadius="20"
           Padding="24"
           WidthRequest="450"
           VerticalOptions="Center"
           HorizontalOptions="Center"
           HasShadow="True">

        <VerticalStackLayout Spacing="20">
            <!-- Header -->
            <HorizontalStackLayout Spacing="12">
                <Border BackgroundColor="#F3F0FA" StrokeShape="RoundRectangle 10" Padding="8" StrokeThickness="0">
                    <Path Data="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z" 
                          Fill="#624890" Aspect="Uniform" HeightRequest="20" WidthRequest="20" />
                </Border>
                <VerticalStackLayout VerticalOptions="Center">
                    <Label Text="Add New User" FontSize="20" FontAttributes="Bold" TextColor="#463366" />
                    <Label x:Name="TierContextLabel" Text="Standard Tier (Company Only)" FontSize="12" TextColor="#7D6A9E" />
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <!-- Form Fields -->
            <Grid RowDefinitions="Auto,Auto,Auto,Auto" RowSpacing="15">
                <!-- First Name -->
                <VerticalStackLayout Grid.Row="0" Spacing="5">
                    <Label Text="First Name" FontSize="12" FontAttributes="Bold" TextColor="#463366" />
                    <Entry x:Name="FirstNameEntry" Placeholder="Enter first name" BackgroundColor="#F8FAFC" />
                </VerticalStackLayout>

                <!-- Last Name -->
                <VerticalStackLayout Grid.Row="1" Spacing="5">
                    <Label Text="Last Name" FontSize="12" FontAttributes="Bold" TextColor="#463366" />
                    <Entry x:Name="LastNameEntry" Placeholder="Enter last name" BackgroundColor="#F8FAFC" />
                </VerticalStackLayout>

                <!-- Email -->
                <VerticalStackLayout Grid.Row="2" Spacing="5">
                    <Label Text="Email Address" FontSize="12" FontAttributes="Bold" TextColor="#463366" />
                    <Entry x:Name="EmailEntry" Keyboard="Email" Placeholder="user@company.com" BackgroundColor="#F8FAFC" />
                </VerticalStackLayout>

                <!-- Role -->
                <VerticalStackLayout Grid.Row="3" Spacing="5">
                    <Label Text="Account Role" FontSize="12" FontAttributes="Bold" TextColor="#463366" />
                    <Border StrokeShape="RoundRectangle 8" StrokeThickness="1" Stroke="#E2E8F0">
                        <Picker x:Name="RolePicker" Title="Select user role" TitleColor="#94A3B8" TextColor="#463366">
                            <Picker.Items>
                                <x:String>Staff</x:String>
                                <x:String>Supplier</x:String>
                            </Picker.Items>
                        </Picker>
                    </Border>
                </VerticalStackLayout>
            </Grid>

            <!-- Password Entry -->
            <VerticalStackLayout Spacing="5">
                <Label Text="Account Password" FontSize="12" FontAttributes="Bold" TextColor="#463366" />
                <Entry x:Name="PasswordEntry" IsPassword="True" Placeholder="Create account password" BackgroundColor="#F8FAFC" />
            </VerticalStackLayout>

            <!-- Actions -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="12" Margin="0,10,0,0">
                <Button Grid.Column="0" Text="Cancel" Clicked="OnCancelClicked"
                        BackgroundColor="Transparent" TextColor="#64748B" BorderColor="#E2E8F0" BorderWidth="1" />
                <Button Grid.Column="1" Text="Create User" Clicked="OnSaveClicked"
                        BackgroundColor="#624890" TextColor="White" />
            </Grid>
        </VerticalStackLayout>
    </Frame>
</ContentPage>
