<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:IT13_AviahC.Views.Admin.Components"
             x:Class="IT13_AviahC.Views.Admin.AdminPromotionsPage"
             BackgroundColor="#F3F0FA">
    <Grid ColumnDefinitions="Auto,*">
        <!-- Reusable Sidebar -->
        <components:AdminSidebarView Grid.Column="0" CurrentPage="AdminPromotions" />

        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <!-- Header -->
            <components:AdminHeaderView Grid.Row="0" />

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="32" Spacing="24">
                    <!-- Title Row -->
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="% CRM Promotions &amp; Discounts" FontSize="24" FontAttributes="Bold" TextColor="#463366" />
                            <Label Text="Configure promotional campaigns with auto-apply rules" FontSize="14" TextColor="#7D6A9E" />
                        </VerticalStackLayout>
                        <Button Grid.Column="1" Text="+ Create Promotion" BackgroundColor="#624890" TextColor="White" CornerRadius="12" Padding="20,0" FontAttributes="Bold" HeightRequest="40" VerticalOptions="Center" />
                    </Grid>

                    <!-- Stats Row -->
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="20">
                        <Border BackgroundColor="White" StrokeShape="RoundRectangle 16" Padding="20" StrokeThickness="0">
                            <HorizontalStackLayout Spacing="16">
                                <Border BackgroundColor="#DCFCE7" StrokeShape="RoundRectangle 12" HeightRequest="48" WidthRequest="48" StrokeThickness="0">
                                    <Path Data="M12.89,3L14.85,3.4L11.11,21L9.15,20.6L12.89,3M19.59,12L16,8.41V5.59L21.41,11V13L16,18.41V15.59L19.59,12M3,11V13L8.41,18.41V15.59L4.83,12L8.41,8.41V5.59L3,11Z"
                                          Fill="#15803D" Aspect="Uniform" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout VerticalOptions="Center">
                                    <Label Text="Active Promos" TextColor="#94A3B8" FontSize="12" FontAttributes="Bold" />
                                    <Label Text="3" TextColor="#1E293B" FontSize="24" FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>

                        <Border Grid.Column="1" BackgroundColor="White" StrokeShape="RoundRectangle 16" Padding="20" StrokeThickness="0">
                            <HorizontalStackLayout Spacing="16">
                                <Border BackgroundColor="#DBEAFE" StrokeShape="RoundRectangle 12" HeightRequest="48" WidthRequest="48" StrokeThickness="0">
                                    <Path Data="M16,13C15.71,13 15.38,13 15.03,13.05C16.19,13.89 17,15 17,16.5V19H23V16.5C23,14.17 18.33,13 16,13M16,7A4,4 0 0,0 12,11A4,4 0 0,0 16,15A4,4 0 0,0 20,11A4,4 0 0,0 16,7M9,13C6.67,13 2,14.17 2,16.5V19H16V16.5C16,14.17 11.33,13 9,13M9,7A4,4 0 0,0 5,11A4,4 0 0,0 9,15A4,4 0 0,0 13,11A4,4 0 0,0 9,7Z"
                                          Fill="#2563EB" Aspect="Uniform" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout VerticalOptions="Center">
                                    <Label Text="Total Usage" TextColor="#94A3B8" FontSize="12" FontAttributes="Bold" />
                                    <Label Text="146" TextColor="#1E293B" FontSize="24" FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>

                        <Border Grid.Column="2" BackgroundColor="White" StrokeShape="RoundRectangle 16" Padding="20" StrokeThickness="0">
                            <HorizontalStackLayout Spacing="16">
                                <Border BackgroundColor="#F3E8FF" StrokeShape="RoundRectangle 12" HeightRequest="48" WidthRequest="48" StrokeThickness="0">
                                    <Path Data="M18.5,4L19.66,8.33L24,9.5L19.66,10.67L18.5,15L17.33,10.67L13,9.5L17.33,8.33L18.5,4M6,1L8.06,8.06L15.12,10.12L8.06,12.19L6,19.25L3.94,12.19L-3.12,10.12L3.94,8.06L6,1M13,14L14.33,19L19.33,20.33L14.33,21.67L13,26.67L11.67,21.67L6.67,20.33L11.67,19L13,14"
                                          Fill="#9333EA" Aspect="Uniform" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout VerticalOptions="Center">
                                    <Label Text="Avg Discount" TextColor="#94A3B8" FontSize="12" FontAttributes="Bold" />
                                    <Label Text="18.3%" TextColor="#1E293B" FontSize="24" FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>

                        <Border Grid.Column="3" BackgroundColor="White" StrokeShape="RoundRectangle 16" Padding="20" StrokeThickness="0">
                            <HorizontalStackLayout Spacing="16">
                                <Border BackgroundColor="#FEF3C7" StrokeShape="RoundRectangle 12" HeightRequest="48" WidthRequest="48" StrokeThickness="0">
                                    <Path Data="M5,16L3,5L8.5,10L12,4L15.5,10L21,5L19,16H5M19,19A1,1 0 0,1 18,20H6A1,1 0 0,1 5,19V18H19V19Z"
                                          Fill="#D97706" Aspect="Uniform" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" VerticalOptions="Center" />
                                </Border>
                                <VerticalStackLayout VerticalOptions="Center">
                                    <Label Text="Revenue Impact" TextColor="#94A3B8" FontSize="12" FontAttributes="Bold" />
                                    <Label Text="+15%" TextColor="#1E293B" FontSize="24" FontAttributes="Bold" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Active Promotions Section -->
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="0" StrokeThickness="0">
                        <VerticalStackLayout Spacing="0">
                            <Label Text="Active Promotions" FontAttributes="Bold" FontSize="16" TextColor="#463366" Padding="32,24" />
                            
                            <Grid ColumnDefinitions="2*,*,*,1.5*,*,*,Auto" Padding="32,0,32,8" ColumnSpacing="10">
                                <Label Text="Promotion" FontAttributes="Bold" FontSize="12" TextColor="#64748B" />
                                <Label Grid.Column="1" Text="Type &amp; Value" FontAttributes="Bold" FontSize="12" TextColor="#64748B" />
                                <Label Grid.Column="2" Text="Target" FontAttributes="Bold" FontSize="12" TextColor="#64748B" />
                                <Label Grid.Column="3" Text="Duration" FontAttributes="Bold" FontSize="12" TextColor="#64748B" />
                                <Label Grid.Column="4" Text="Usage" FontAttributes="Bold" FontSize="12" TextColor="#64748B" />
                                <Label Grid.Column="5" Text="Status" FontAttributes="Bold" FontSize="12" TextColor="#64748B" />
                                <Label Grid.Column="6" Text="Actions" FontAttributes="Bold" FontSize="12" TextColor="#64748B" HorizontalTextAlignment="End" />
                            </Grid>

                            <CollectionView x:Name="ActivePromosCollection">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="2*,*,*,1.5*,*,*,Auto" Padding="32,16" ColumnSpacing="10">
                                            <VerticalStackLayout Spacing="2">
                                                <Label Text="{Binding PromotionName}" FontAttributes="Bold" FontSize="14" TextColor="#1E293B" />
                                                <Label Text="{Binding PromoCode}" FontSize="11" TextColor="#94A3B8" />
                                            </VerticalStackLayout>
                                            <Border Grid.Column="1" BackgroundColor="#F3E8FF" StrokeShape="RoundRectangle 8" Padding="12,4" HorizontalOptions="Start" VerticalOptions="Center" StrokeThickness="0">
                                                <Label Text="{Binding DiscountValue}" FontSize="11" TextColor="#9333EA" FontAttributes="Bold" />
                                            </Border>
                                            <Label Grid.Column="2" Text="{Binding TargetAudience}" FontSize="13" TextColor="#64748B" VerticalOptions="Center" />
                                            <HorizontalStackLayout Grid.Column="3" Spacing="8" VerticalOptions="Center">
                                                <Path Data="M19,4H18V2H16V4H8V2H6V4H5C3.89,4 3,4.9 3,6V19A2,2 0 0,0 5,21H19A2,2 0 0,0 21,19V6A2,2 0 0,0 19,4M19,19H5V10H19V19M19,8H5V6H19V8Z"
                                                      Fill="#94A3B8" Aspect="Uniform" HeightRequest="14" WidthRequest="14" VerticalOptions="Center" />
                                                <Label Text="{Binding Duration}" FontSize="12" TextColor="#64748B" VerticalOptions="Center" />
                                            </HorizontalStackLayout>
                                            <VerticalStackLayout Grid.Column="4" Spacing="4" VerticalOptions="Center">
                                                <Label Text="{Binding UsageText}" FontSize="12" TextColor="#1E293B" FontAttributes="Bold" />
                                                <ProgressBar Progress="{Binding UsageProgress}" ProgressColor="#624890" HeightRequest="4" />
                                            </VerticalStackLayout>
                                            <Border Grid.Column="5" BackgroundColor="#DCFCE7" StrokeShape="RoundRectangle 12" Padding="10,4" HorizontalOptions="Start" VerticalOptions="Center" StrokeThickness="0">
                                                <Label Text="{Binding Status}" FontSize="11" TextColor="#15803D" FontAttributes="Bold" />
                                            </Border>
                                            <HorizontalStackLayout Grid.Column="6" Spacing="16" HorizontalOptions="End" VerticalOptions="Center">
                                                <Path Data="M20.71,7.04C21.1,6.65 21.1,6 20.71,5.63L18.37,3.29C18,2.9 17.35,2.9 16.96,3.29L15.12,5.12L18.87,8.87M3,17.25V21H6.75L17.81,9.93L14.06,6.18L3,17.25Z"
                                                      Fill="#624890" Aspect="Uniform" HeightRequest="16" WidthRequest="16" />
                                                <Path Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19V4M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                                                      Fill="#EF4444" Aspect="Uniform" HeightRequest="16" WidthRequest="16" />
                                            </HorizontalStackLayout>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Past Promotions Section -->
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="0" StrokeThickness="0" Margin="0,0,0,32">
                        <VerticalStackLayout Spacing="0">
                            <Label Text="Past Promotions (Performance)" FontAttributes="Bold" FontSize="16" TextColor="#463366" Padding="32,24" />
                            <Grid ColumnDefinitions="2*,*,*,*,*,Auto" Padding="32,0,32,16" ColumnSpacing="10">
                                <Label Text="Promotion" FontAttributes="Bold" FontSize="12" TextColor="#64748B" />
                                <Label Grid.Column="1" Text="Type &amp; Value" FontAttributes="Bold" FontSize="12" TextColor="#64748B" />
                                <Label Grid.Column="2" Text="Duration" FontAttributes="Bold" FontSize="12" TextColor="#64748B" />
                                <Label Grid.Column="3" Text="Usage" FontAttributes="Bold" FontSize="12" TextColor="#64748B" />
                                <Label Grid.Column="4" Text="Revenue Generated" FontAttributes="Bold" FontSize="12" TextColor="#64748B" />
                                <Label Grid.Column="5" Text="Status" FontAttributes="Bold" FontSize="12" TextColor="#64748B" HorizontalTextAlignment="End" />
                            </Grid>
                            
                            <!-- Static example for design completeness -->
                            <Grid ColumnDefinitions="2*,*,*,*,*,Auto" Padding="32,16" ColumnSpacing="10" BackgroundColor="#F8FAFC">
                                <VerticalStackLayout Spacing="2">
                                    <Label Text="Summer Collection Launch" FontAttributes="Bold" FontSize="14" TextColor="#1E293B" />
                                    <Label Text="PROMO-999" FontSize="11" TextColor="#94A3B8" />
                                </VerticalStackLayout>
                                <Border Grid.Column="1" BackgroundColor="#F1F5F9" StrokeShape="RoundRectangle 8" Padding="12,4" HorizontalOptions="Start" VerticalOptions="Center" StrokeThickness="0">
                                    <Label Text="25% OFF" FontSize="11" TextColor="#64748B" FontAttributes="Bold" />
                                </Border>
                                <Label Grid.Column="2" Text="2026-03-01 - 2026-03-31" FontSize="12" TextColor="#64748B" VerticalOptions="Center" />
                                <HorizontalStackLayout Grid.Column="3" Spacing="4" VerticalOptions="Center">
                                    <Label Text="203 / 200" FontSize="12" TextColor="#1E293B" FontAttributes="Bold" />
                                    <Label Text="(101%)" FontSize="10" TextColor="#10B981" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <Label Grid.Column="4" Text="₱125,400" FontSize="14" FontAttributes="Bold" TextColor="#10B981" VerticalOptions="Center" />
                                <Border Grid.Column="5" BackgroundColor="#F1F5F9" StrokeShape="RoundRectangle 12" Padding="10,4" HorizontalOptions="End" VerticalOptions="Center" StrokeThickness="0">
                                    <Label Text="Expired" FontSize="11" TextColor="#64748B" FontAttributes="Bold" />
                                </Border>
                            </Grid>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>
