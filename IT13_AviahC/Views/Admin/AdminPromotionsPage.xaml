<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:IT13_AviahC.Views.Admin.Components"
             x:Class="IT13_AviahC.Views.Admin.AdminPromotionsPage"
             BackgroundColor="#F8FAFC"
             Shell.NavBarIsVisible="False">

    <Grid ColumnDefinitions="Auto,*">
        <!-- Sidebar -->
        <components:AdminSidebarView Grid.Column="0" CurrentPage="AdminPromotions" />

        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <!-- Header -->
            <components:AdminHeaderView Grid.Row="0" />

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="30" Spacing="25">
                    
                    <!-- Title Row -->
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Product Promotions" FontSize="28" FontAttributes="Bold" TextColor="#1E293B" />
                            <Label Text="Manage discounts and special offers for your boutique." TextColor="#64748B" FontSize="14" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1" BackgroundColor="#F1F5F9" Padding="15,8" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                            <Label x:Name="PromoCountLabel" Text="0 Active Promos" TextColor="#475569" FontAttributes="Bold" FontSize="12" />
                        </Border>
                    </Grid>

                    <!-- Inventory Table -->
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 20" Padding="0" StrokeThickness="0">
                        <VerticalStackLayout Spacing="0">
                            <!-- Table Header -->
                            <Grid ColumnDefinitions="2*,*,*,*,Auto" Padding="25,20" BackgroundColor="#F8FAFC">
                                <Label Text="PRODUCT" FontAttributes="Bold" FontSize="12" TextColor="#64748B" />
                                <Label Grid.Column="1" Text="REGULAR PRICE" FontAttributes="Bold" FontSize="12" TextColor="#64748B" />
                                <Label Grid.Column="2" Text="DISCOUNT PRICE" FontAttributes="Bold" FontSize="12" TextColor="#64748B" />
                                <Label Grid.Column="3" Text="STATUS" FontAttributes="Bold" FontSize="12" TextColor="#64748B" />
                                <Label Grid.Column="4" Text="ACTION" FontAttributes="Bold" FontSize="12" TextColor="#64748B" HorizontalTextAlignment="End" />
                            </Grid>

                            <CollectionView x:Name="ProductsCollection" Margin="0,0,0,10">
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="2*,*,*,*,Auto" Padding="25,15" ColumnSpacing="10">
                                            <!-- Product Info -->
                                            <HorizontalStackLayout Spacing="15">
                                                <Border StrokeShape="RoundRectangle 8" StrokeThickness="0" HeightRequest="40" WidthRequest="40">
                                                    <Image Source="{Binding ImageUrl}" Aspect="AspectFill" />
                                                </Border>
                                                <VerticalStackLayout VerticalOptions="Center">
                                                    <Label Text="{Binding ProductName}" FontAttributes="Bold" FontSize="14" TextColor="#1E293B" />
                                                    <Label Text="{Binding Category}" FontSize="12" TextColor="#94A3B8" />
                                                </VerticalStackLayout>
                                            </HorizontalStackLayout>

                                            <!-- Prices -->
                                            <Label Grid.Column="1" Text="{Binding FormattedPrice}" VerticalOptions="Center" TextColor="#64748B" FontSize="14" />
                                            <Label Grid.Column="2" Text="{Binding FormattedDiscountPrice}" VerticalOptions="Center" TextColor="#EF4444" FontAttributes="Bold" FontSize="14" />

                                            <!-- Status -->
                                            <Border Grid.Column="3" Padding="10,4" HorizontalOptions="Start" VerticalOptions="Center" StrokeShape="RoundRectangle 8" StrokeThickness="0" BackgroundColor="{Binding PromoStatusColor}">
                                                <Label Text="{Binding PromoStatusText}" TextColor="{Binding PromoStatusTextColor}" FontSize="11" FontAttributes="Bold" />
                                            </Border>

                                            <!-- Actions -->
                                            <HorizontalStackLayout Grid.Column="4" Spacing="10" HorizontalOptions="End" VerticalOptions="Center">
                                                <Button Text="Apply Promo" 
                                                        Clicked="OnApplyPromoClicked"
                                                        CommandParameter="{Binding .}"
                                                        BackgroundColor="#6366F1" 
                                                        TextColor="White" 
                                                        FontSize="11" 
                                                        HeightRequest="32" 
                                                        Padding="12,0" 
                                                        CornerRadius="8" />
                                                <Button Text="Remove" 
                                                        Clicked="OnRemovePromoClicked"
                                                        CommandParameter="{Binding .}"
                                                        IsVisible="{Binding IsOnPromotion}"
                                                        BackgroundColor="#FEE2E2" 
                                                        TextColor="#EF4444" 
                                                        FontSize="11" 
                                                        HeightRequest="32" 
                                                        Padding="12,0" 
                                                        CornerRadius="8" />
                                            </HorizontalStackLayout>
                                        </Grid>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>

        <!-- Promotion Modal -->
        <Grid x:Name="PromoModal" Grid.ColumnSpan="2" BackgroundColor="#80000000" IsVisible="False">
            <Border BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="30" WidthRequest="450" HorizontalOptions="Center" VerticalOptions="Center" StrokeThickness="0">
                <VerticalStackLayout Spacing="20">
                    <Label x:Name="ModalTitleLabel" Text="Apply Promotion" FontSize="20" FontAttributes="Bold" TextColor="#1E293B" />
                    
                    <VerticalStackLayout Spacing="8">
                        <Label Text="Regular Price" FontSize="12" FontAttributes="Bold" TextColor="#64748B" />
                        <Border BackgroundColor="#F8FAFC" Padding="15" StrokeShape="RoundRectangle 12" StrokeThickness="0">
                            <Label x:Name="RegularPriceLabel" Text="₱0.00" TextColor="#1E293B" FontAttributes="Bold" />
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="8">
                        <Label Text="Promotional Price (Discounted)" FontSize="12" FontAttributes="Bold" TextColor="#64748B" />
                        <Entry x:Name="DiscountPriceEntry" TextColor="White" Placeholder="Enter new price..." Keyboard="Numeric" BackgroundColor="#F8FAFC" HeightRequest="50" />
                    </VerticalStackLayout>

                    <Label Text="This product will be moved to the Special Offers page and removed from the Boutique until the promotion ends." FontSize="12" TextColor="#64748B" HorizontalTextAlignment="Center" />

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="15">
                        <Button Text="Cancel" Clicked="OnCloseModalClicked" BackgroundColor="#F1F5F9" TextColor="#64748B" HeightRequest="50" CornerRadius="12" />
                        <Button Grid.Column="1" Text="Save Promo" Clicked="OnSavePromoClicked" BackgroundColor="#6366F1" TextColor="White" HeightRequest="50" CornerRadius="12" FontAttributes="Bold" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </Grid>
</ContentPage>
