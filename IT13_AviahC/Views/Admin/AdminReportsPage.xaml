<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:IT13_AviahC.Views.Admin.Components"
             x:Class="IT13_AviahC.Views.Admin.AdminReportsPage"
             BackgroundColor="#F3F0FA">
    <Grid ColumnDefinitions="Auto,*">
        <!-- Reusable Sidebar -->
        <components:AdminSidebarView Grid.Column="0" CurrentPage="AdminReports" />

        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <!-- Header -->
            <components:AdminHeaderView Grid.Row="0" />

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="32" Spacing="24">
                    <!-- Title Row -->
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Business Reports &amp; Analytics" FontSize="24" FontAttributes="Bold" TextColor="#463366" />
                            <Label Text="Comprehensive insights into your business performance" FontSize="14" TextColor="#7D6A9E" />
                        </VerticalStackLayout>
                        <HorizontalStackLayout Grid.Column="1" Spacing="12">
                            <Border BackgroundColor="White" StrokeShape="RoundRectangle 12" Padding="16,8" StrokeThickness="0">
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="Last Month" TextColor="#64748B" FontSize="13" VerticalOptions="Center" />
                                    <Path Data="M7,10L12,15L17,10H7Z" Fill="#64748B" HeightRequest="16" WidthRequest="16" VerticalOptions="Center" />
                                </HorizontalStackLayout>
                            </Border>
                            <Button Text="Export PDF" BackgroundColor="#624890" TextColor="White" CornerRadius="12" Padding="20,0" FontAttributes="Bold" FontSize="13" HeightRequest="40" />
                        </HorizontalStackLayout>
                    </Grid>

                    <!-- Stats Cards Row -->
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="20">
                        <Border BackgroundColor="White" StrokeShape="RoundRectangle 20" Padding="24" StrokeThickness="0">
                            <VerticalStackLayout Spacing="12">
                                <HorizontalStackLayout Spacing="12">
                                    <Border BackgroundColor="#DCFCE7" StrokeShape="RoundRectangle 12" HeightRequest="44" WidthRequest="44" StrokeThickness="0">
                                        <Label Text="₱" TextColor="#15803D" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout>
                                        <Label Text="Total Revenue" TextColor="#94A3B8" FontSize="12" FontAttributes="Bold" />
                                        <Label Text="₱314,000" TextColor="#1E293B" FontSize="24" FontAttributes="Bold" />
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                                <Label Text="+12.5% from last period" TextColor="#10B981" FontSize="11" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1" BackgroundColor="White" StrokeShape="RoundRectangle 20" Padding="24" StrokeThickness="0">
                            <VerticalStackLayout Spacing="12">
                                <HorizontalStackLayout Spacing="12">
                                    <Border BackgroundColor="#DBEAFE" StrokeShape="RoundRectangle 12" HeightRequest="44" WidthRequest="44" StrokeThickness="0">
                                        <Path Data="M10,2L2,7V17L10,22L18,17V7L10,2M10,4.3L16,8V10.7L10,7.1V4.3M10,14.7L4,11.1V8.4L10,12V14.7M10,20L4,16.4V13.7L10,17.3V20M16,16.4L10,20V17.3L16,13.7V16.4M16,11.1L10,14.7V12L16,8.4V11.1Z"
                                              Fill="#2563EB" Aspect="Uniform" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout>
                                        <Label Text="Items Sold" TextColor="#94A3B8" FontSize="12" FontAttributes="Bold" />
                                        <Label Text="1,245" TextColor="#1E293B" FontSize="24" FontAttributes="Bold" />
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                                <Label Text="-8.2% from last period" TextColor="#EF4444" FontSize="11" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="2" BackgroundColor="White" StrokeShape="RoundRectangle 20" Padding="24" StrokeThickness="0">
                            <VerticalStackLayout Spacing="12">
                                <HorizontalStackLayout Spacing="12">
                                    <Border BackgroundColor="#F3E8FF" StrokeShape="RoundRectangle 12" HeightRequest="44" WidthRequest="44" StrokeThickness="0">
                                        <Path Data="M12,4A4,4 0 0,1 16,8A4,4 0 0,1 12,12A4,4 0 0,1 8,8A4,4 0 0,1 12,4M12,14C16.42,14 20,15.79 20,18V20H4V18C4,15.79 7.58,14 12,14Z"
                                              Fill="#9333EA" Aspect="Uniform" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout>
                                        <Label Text="New Customers" TextColor="#94A3B8" FontSize="12" FontAttributes="Bold" />
                                        <Label Text="89" TextColor="#1E293B" FontSize="24" FontAttributes="Bold" />
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                                <Label Text="+15.3% from last period" TextColor="#10B981" FontSize="11" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="3" BackgroundColor="White" StrokeShape="RoundRectangle 20" Padding="24" StrokeThickness="0">
                            <VerticalStackLayout Spacing="12">
                                <HorizontalStackLayout Spacing="12">
                                    <Border BackgroundColor="#FEF3C7" StrokeShape="RoundRectangle 12" HeightRequest="44" WidthRequest="44" StrokeThickness="0">
                                        <Label Text="%" TextColor="#D97706" FontSize="20" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <VerticalStackLayout>
                                        <Label Text="Profit Margin" TextColor="#94A3B8" FontSize="12" FontAttributes="Bold" />
                                        <Label Text="42.8%" TextColor="#1E293B" FontSize="24" FontAttributes="Bold" />
                                    </VerticalStackLayout>
                                </HorizontalStackLayout>
                                <Label Text="+2.1% from last period" TextColor="#10B981" FontSize="11" FontAttributes="Bold" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Main Chart Row -->
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="32" StrokeThickness="0">
                        <VerticalStackLayout Spacing="24">
                            <Label Text="Sales &amp; Profit Trends" FontSize="18" FontAttributes="Bold" TextColor="#463366" />
                            
                            <!-- Simple Line Chart Visual -->
                            <Grid HeightRequest="300">
                                <Path Data="M0,200 L100,180 L200,210 L300,160 L400,170 L500,140 L600,120 L700,100" Stroke="#624890" StrokeThickness="3" Aspect="Fill" />
                                <Path Data="M0,250 L100,240 L200,255 L300,230 L400,235 L500,220 L600,210 L700,200" Stroke="#10B981" StrokeThickness="2" Aspect="Fill" />
                                
                                <BoxView HeightRequest="1" BackgroundColor="#F1F5F9" VerticalOptions="End" />
                                <Grid ColumnDefinitions="*,*,*,*,*,*,*" VerticalOptions="End" Margin="0,10,0,0">
                                    <Label Grid.Column="0" Text="Jan" TextColor="#94A3B8" FontSize="11" HorizontalOptions="Start" />
                                    <Label Grid.Column="1" Text="Feb" TextColor="#94A3B8" FontSize="11" HorizontalOptions="Center" />
                                    <Label Grid.Column="2" Text="Mar" TextColor="#94A3B8" FontSize="11" HorizontalOptions="Center" />
                                    <Label Grid.Column="3" Text="Apr" TextColor="#94A3B8" FontSize="11" HorizontalOptions="Center" />
                                    <Label Grid.Column="4" Text="May" TextColor="#94A3B8" FontSize="11" HorizontalOptions="Center" />
                                    <Label Grid.Column="5" Text="Jun" TextColor="#94A3B8" FontSize="11" HorizontalOptions="End" />
                                </Grid>
                            </Grid>
                            
                            <HorizontalStackLayout HorizontalOptions="Center" Spacing="24">
                                <HorizontalStackLayout Spacing="8">
                                    <Ellipse WidthRequest="10" HeightRequest="10" Fill="#624890" />
                                    <Label Text="Sales" FontSize="12" TextColor="#64748B" />
                                </HorizontalStackLayout>
                                <HorizontalStackLayout Spacing="8">
                                    <Ellipse WidthRequest="10" HeightRequest="10" Fill="#10B981" />
                                    <Label Text="Profit" FontSize="12" TextColor="#64748B" />
                                </HorizontalStackLayout>
                            </HorizontalStackLayout>
                        </VerticalStackLayout>
                    </Border>

                    <!-- Pie Chart and Turnover Row -->
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="20">
                        <Border BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="32" StrokeThickness="0">
                            <VerticalStackLayout Spacing="24">
                                <Label Text="Sales by Category" FontSize="18" FontAttributes="Bold" TextColor="#463366" />
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="24">
                                    <Grid HeightRequest="200" WidthRequest="200">
                                        <Ellipse Fill="#624890" />
                                        <Path Data="M100,100 L100,0 A100,100 0 0,1 186.6,50 Z" Fill="#7D6A9E" />
                                        <Path Data="M100,100 L186.6,50 A100,100 0 0,1 186.6,150 Z" Fill="#A799C0" />
                                        <Path Data="M100,100 L186.6,150 A100,100 0 0,1 100,200 Z" Fill="#D1C4E9" />
                                    </Grid>
                                    <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="16">
                                        <Label Text="Dresses: 45%" TextColor="#64748B" FontSize="13" />
                                        <Label Text="Tops: 28%" TextColor="#64748B" FontSize="13" />
                                        <Label Text="Bottoms: 18%" TextColor="#64748B" FontSize="13" />
                                        <Label Text="Accessories: 9%" TextColor="#64748B" FontSize="13" />
                                    </VerticalStackLayout>
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <Border Grid.Column="1" BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="32" StrokeThickness="0">
                            <VerticalStackLayout Spacing="24">
                                <Label Text="Inventory Turnover Rate" FontSize="18" FontAttributes="Bold" TextColor="#463366" />
                                <VerticalStackLayout Spacing="20">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Spacing="4">
                                            <Label Text="Violet Summer Dress" FontAttributes="Bold" FontSize="14" TextColor="#1E293B" />
                                            <Label Text="Current Stock: 45" FontSize="11" TextColor="#94A3B8" />
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="4">
                                            <Label Text="8.5x" FontAttributes="Bold" TextColor="#1E293B" HorizontalOptions="End" />
                                            <Label Text="Normal" FontSize="11" TextColor="#94A3B8" HorizontalOptions="End" />
                                        </VerticalStackLayout>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Spacing="4">
                                            <Label Text="Lavender Blouse" FontAttributes="Bold" FontSize="14" TextColor="#1E293B" />
                                            <Label Text="Current Stock: 12" FontSize="11" TextColor="#94A3B8" />
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="4">
                                            <Label Text="12.3x" FontAttributes="Bold" TextColor="#10B981" HorizontalOptions="End" />
                                            <Label Text="High Demand" FontSize="11" TextColor="#10B981" HorizontalOptions="End" />
                                        </VerticalStackLayout>
                                    </Grid>
                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Spacing="4">
                                            <Label Text="Premium Cotton Fabric" FontAttributes="Bold" FontSize="14" TextColor="#1E293B" />
                                            <Label Text="Current Stock: 450" FontSize="11" TextColor="#94A3B8" />
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="1" HorizontalOptions="End" Spacing="4">
                                            <Label Text="6.2x" FontAttributes="Bold" TextColor="#D97706" HorizontalOptions="End" />
                                            <Label Text="Slow Moving" FontSize="11" TextColor="#D97706" HorizontalOptions="End" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Supplier Performance Section -->
                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="0" StrokeThickness="0" Margin="0,0,0,32">
                        <VerticalStackLayout Spacing="0">
                            <HorizontalStackLayout Padding="32,24" Spacing="12">
                                <Border BackgroundColor="#624890" StrokeShape="RoundRectangle 4" Padding="8,2" StrokeThickness="0">
                                    <Label Text="PREMIUM" TextColor="White" FontSize="10" FontAttributes="Bold" />
                                </Border>
                                <Label Text="Supplier Performance Analytics" FontAttributes="Bold" FontSize="16" TextColor="#463366" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                            
                            <Grid ColumnDefinitions="2*,*,*,*,*" Padding="32,16" BackgroundColor="#F3F0FA" ColumnSpacing="10">
                                <Label Text="Supplier" FontAttributes="Bold" FontSize="12" TextColor="#64748B" />
                                <Label Grid.Column="1" Text="On-Time Delivery" FontAttributes="Bold" FontSize="12" TextColor="#64748B" HorizontalTextAlignment="Center" />
                                <Label Grid.Column="2" Text="Quality Score" FontAttributes="Bold" FontSize="12" TextColor="#64748B" HorizontalTextAlignment="Center" />
                                <Label Grid.Column="3" Text="Total Orders" FontAttributes="Bold" FontSize="12" TextColor="#64748B" HorizontalTextAlignment="Center" />
                                <Label Grid.Column="4" Text="Rating" FontAttributes="Bold" FontSize="12" TextColor="#64748B" HorizontalTextAlignment="End" />
                            </Grid>

                            <!-- Supplier Rows -->
                            <VerticalStackLayout x:Name="SupplierPerformanceList">
                                <Grid ColumnDefinitions="2*,*,*,*,*" Padding="32,20" ColumnSpacing="10">
                                    <Label Text="Fabric Co." FontAttributes="Bold" FontSize="14" TextColor="#1E293B" VerticalOptions="Center" />
                                    <Border Grid.Column="1" BackgroundColor="#DCFCE7" StrokeShape="RoundRectangle 12" Padding="12,4" HorizontalOptions="Center" StrokeThickness="0">
                                        <Label Text="95%" TextColor="#15803D" FontSize="11" FontAttributes="Bold" />
                                    </Border>
                                    <Border Grid.Column="2" BackgroundColor="#DCFCE7" StrokeShape="RoundRectangle 12" Padding="12,4" HorizontalOptions="Center" StrokeThickness="0">
                                        <Label Text="98%" TextColor="#15803D" FontSize="11" FontAttributes="Bold" />
                                    </Border>
                                    <Label Grid.Column="3" Text="24" TextColor="#1E293B" FontSize="14" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                    <Label Grid.Column="4" Text="★★★★★" TextColor="#FBBF24" FontSize="14" HorizontalTextAlignment="End" VerticalOptions="Center" />
                                </Grid>
                                <BoxView HeightRequest="1" BackgroundColor="#F1F5F9" Margin="32,0" />
                                
                                <Grid ColumnDefinitions="2*,*,*,*,*" Padding="32,20" ColumnSpacing="10">
                                    <Label Text="Thread Supplies Inc." FontAttributes="Bold" FontSize="14" TextColor="#1E293B" VerticalOptions="Center" />
                                    <Border Grid.Column="1" BackgroundColor="#FEF3C7" StrokeShape="RoundRectangle 12" Padding="12,4" HorizontalOptions="Center" StrokeThickness="0">
                                        <Label Text="88%" TextColor="#D97706" FontSize="11" FontAttributes="Bold" />
                                    </Border>
                                    <Border Grid.Column="2" BackgroundColor="#DCFCE7" StrokeShape="RoundRectangle 12" Padding="12,4" HorizontalOptions="Center" StrokeThickness="0">
                                        <Label Text="92%" TextColor="#15803D" FontSize="11" FontAttributes="Bold" />
                                    </Border>
                                    <Label Grid.Column="3" Text="18" TextColor="#1E293B" FontSize="14" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                    <Label Grid.Column="4" Text="★★★★☆" TextColor="#FBBF24" FontSize="14" HorizontalTextAlignment="End" VerticalOptions="Center" />
                                </Grid>
                            </VerticalStackLayout>
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>
