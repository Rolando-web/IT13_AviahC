<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:IT13_AviahC.Views.Admin.Components"
             x:Class="IT13_AviahC.Views.Admin.AdminDashboardPage"
             BackgroundColor="#F3F0FA">
    <Grid ColumnDefinitions="Auto,*">
        <!-- Reusable Sidebar -->
        <components:AdminSidebarView Grid.Column="0" CurrentPage="AdminDashboard" />

        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <!-- Header -->
            <components:AdminHeaderView Grid.Row="0" />

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="32" Spacing="24">
                    
                    <!-- Welcome Section -->
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Welcome back, Admin!" FontSize="28" FontAttributes="Bold" TextColor="#463366" />
                            <Label Text="Business Insights &amp; Performance Overview" FontSize="14" TextColor="#7D6A9E" />
                        </VerticalStackLayout>
                        <Border Grid.Column="1" BackgroundColor="White" StrokeShape="RoundRectangle 20" Padding="16,8" StrokeThickness="0">
                            <HorizontalStackLayout Spacing="10">
                                <Ellipse Fill="#FBBF24" HeightRequest="8" WidthRequest="8" VerticalOptions="Center" />
                                <Label Text="Premium Tier" FontSize="13" FontAttributes="Bold" TextColor="#463366" VerticalOptions="Center" />
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Stats Row -->
                    <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="20">
                        <!-- Monthly Sales -->
                        <Border BackgroundColor="White" StrokeShape="RoundRectangle 16" Padding="24" StrokeThickness="0">
                            <VerticalStackLayout Spacing="16">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Border BackgroundColor="#F3F0FA" StrokeShape="RoundRectangle 12" HeightRequest="48" WidthRequest="48" HorizontalOptions="Start" StrokeThickness="0">
                                        <Path Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1.41 16.09V17c0-.55-.45-1-1-1h-1.5c-.28 0-.5-.22-.5-.5s.22-.5.5-.5h2c.83 0 1.5-.67 1.5-1.5V12c0-.83-.67-1.5-1.5-1.5H12V9c0-.55-.45-1-1-1h-1.5c-.28 0-.5-.22-.5-.5s.22-.5.5-.5h2.5c.55 0 1-.45 1-1s-.45-1-1-1H9.41V4c0-.55-.45-1-1-1s-1 .45-1 1v1.09c-1.15.26-2 1.28-2 2.5 0 1.15.74 2.13 1.76 2.45l.24.05V11c0 .55.45 1 1 1h1.5c.28 0 .5.22.5.5s-.22.5-.5.5h-2c-.83 0-1.5.67-1.5 1.5V16c0 .83.67 1.5 1.5 1.5H12v1.59c0 .55.45 1 1 1s1-.45 1-1z"
                                              Fill="#624890" Aspect="Uniform" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Border Grid.Column="1" BackgroundColor="#DCFCE7" StrokeShape="RoundRectangle 10" Padding="8,2" VerticalOptions="Start" StrokeThickness="0">
                                        <Label Text="+8%" FontSize="10" TextColor="#15803D" FontAttributes="Bold" />
                                    </Border>
                                </Grid>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="MONTHLY SALES" FontSize="11" TextColor="#94A3B8" FontAttributes="Bold" CharacterSpacing="1" />
                                    <Label Text="₱124,500" FontSize="24" FontAttributes="Bold" TextColor="#463366" />
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Total Orders -->
                        <Border Grid.Column="1" BackgroundColor="White" StrokeShape="RoundRectangle 16" Padding="24" StrokeThickness="0">
                            <VerticalStackLayout Spacing="16">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Border BackgroundColor="#F3F0FA" StrokeShape="RoundRectangle 12" HeightRequest="48" WidthRequest="48" HorizontalOptions="Start" StrokeThickness="0">
                                        <Path Data="M7 18c-1.1 0-1.99.9-1.99 2S5.9 22 7 22s2-.9 2-2-.9-2-2-2zM1 2v2h2l3.6 7.59-1.35 2.45c-.16.28-.25.61-.25.96 0 1.1.9 2 2 2h12v-2H7.42c-.14 0-.25-.11-.25-.25l.03-.12.9-1.63h7.45c.75 0 1.41-.41 1.75-1.03l3.58-6.49c.08-.14.12-.31.12-.48 0-.55-.45-1-1-1H5.21l-.94-2H1zm16 16c-1.1 0-1.99.9-1.99 2s.89 2 1.99 2 2-.9 2-2-.9-2-2-2z"
                                              Fill="#624890" Aspect="Uniform" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Border Grid.Column="1" BackgroundColor="#DCFCE7" StrokeShape="RoundRectangle 10" Padding="8,2" VerticalOptions="Start" StrokeThickness="0">
                                        <Label Text="+15%" FontSize="10" TextColor="#15803D" FontAttributes="Bold" />
                                    </Border>
                                </Grid>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="TOTAL ORDERS" FontSize="11" TextColor="#94A3B8" FontAttributes="Bold" CharacterSpacing="1" />
                                    <Label Text="842" FontSize="24" FontAttributes="Bold" TextColor="#463366" />
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Low Stock -->
                        <Border Grid.Column="2" BackgroundColor="White" StrokeShape="RoundRectangle 16" Padding="24" StrokeThickness="0">
                            <VerticalStackLayout Spacing="16">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Border BackgroundColor="#F3F0FA" StrokeShape="RoundRectangle 12" HeightRequest="48" WidthRequest="48" HorizontalOptions="Start" StrokeThickness="0">
                                        <Path Data="M21 16.5c0 .38-.21.71-.53.88l-7.97 4.43c-.16.09-.33.14-.5.14s-.34-.05-.5-.14l-7.97-4.43c-.32-.17-.53-.5-.53-.88V7.5c0-.38.21-.71.53-.88l7.97-4.43c.16-.09.33-.14.5-.14s.34.05.5.14l7.97 4.43c.32.17.53.5.53.88v9z"
                                              Fill="#624890" Aspect="Uniform" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Border Grid.Column="1" BackgroundColor="#FEE2E2" StrokeShape="RoundRectangle 10" Padding="8,2" VerticalOptions="Start" StrokeThickness="0">
                                        <Label Text="Warning" FontSize="10" TextColor="#B91C1C" FontAttributes="Bold" />
                                    </Border>
                                </Grid>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="LOW STOCK ITEMS" FontSize="11" TextColor="#94A3B8" FontAttributes="Bold" CharacterSpacing="1" />
                                    <Label Text="12" FontSize="24" FontAttributes="Bold" TextColor="#463366" />
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Conversion Rate -->
                        <Border Grid.Column="3" BackgroundColor="White" StrokeShape="RoundRectangle 16" Padding="24" StrokeThickness="0">
                            <VerticalStackLayout Spacing="16">
                                <Grid ColumnDefinitions="*,Auto">
                                    <Border BackgroundColor="#F3F0FA" StrokeShape="RoundRectangle 12" HeightRequest="48" WidthRequest="48" HorizontalOptions="Start" StrokeThickness="0">
                                        <Path Data="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zM9 17H7v-7h2v7zm4 0h-2V7h2v10zm4 0h-2v-4h2v4z"
                                              Fill="#624890" Aspect="Uniform" HeightRequest="24" WidthRequest="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Border Grid.Column="1" BackgroundColor="#DCFCE7" StrokeShape="RoundRectangle 10" Padding="8,2" VerticalOptions="Start" StrokeThickness="0">
                                        <Label Text="+0.4%" FontSize="10" TextColor="#15803D" FontAttributes="Bold" />
                                    </Border>
                                </Grid>
                                <VerticalStackLayout Spacing="4">
                                    <Label Text="CONVERSION RATE" FontSize="11" TextColor="#94A3B8" FontAttributes="Bold" CharacterSpacing="1" />
                                    <Label Text="3.2%" FontSize="24" FontAttributes="Bold" TextColor="#463366" />
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>

                    <!-- Charts Row -->
                    <Grid ColumnDefinitions="*,400" ColumnSpacing="20">
                        <!-- Sales Overview -->
                        <Border Grid.Column="0" BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="32" StrokeThickness="0">
                            <VerticalStackLayout Spacing="32">
                                <Label Text="Sales Overview" FontSize="18" FontAttributes="Bold" TextColor="#463366" />
                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="16">
                                    <!-- Y-Axis -->
                                    <VerticalStackLayout Spacing="35" VerticalOptions="Fill">
                                        <Label Text="8000" FontSize="11" TextColor="#94A3B8" HorizontalTextAlignment="End" />
                                        <Label Text="6000" FontSize="11" TextColor="#94A3B8" HorizontalTextAlignment="End" />
                                        <Label Text="4000" FontSize="11" TextColor="#94A3B8" HorizontalTextAlignment="End" />
                                        <Label Text="2000" FontSize="11" TextColor="#94A3B8" HorizontalTextAlignment="End" />
                                        <Label Text="0" FontSize="11" TextColor="#94A3B8" HorizontalTextAlignment="End" />
                                    </VerticalStackLayout>
                                    
                                    <!-- Bars -->
                                    <Grid Grid.Column="1" ColumnDefinitions="*,*,*,*,*,*" VerticalOptions="End" HeightRequest="200" ColumnSpacing="12">
                                        <Border Grid.Column="0" BackgroundColor="#624890" StrokeShape="RoundRectangle 8" HeightRequest="120" StrokeThickness="0" WidthRequest="45" VerticalOptions="End" />
                                        <Border Grid.Column="1" BackgroundColor="#624890" StrokeShape="RoundRectangle 8" HeightRequest="90" StrokeThickness="0" WidthRequest="45" VerticalOptions="End" />
                                        <Border Grid.Column="2" BackgroundColor="#624890" StrokeShape="RoundRectangle 8" HeightRequest="140" StrokeThickness="0" WidthRequest="45" VerticalOptions="End" />
                                        <Border Grid.Column="3" BackgroundColor="#624890" StrokeShape="RoundRectangle 8" HeightRequest="130" StrokeThickness="0" WidthRequest="45" VerticalOptions="End" />
                                        <Border Grid.Column="4" BackgroundColor="#624890" StrokeShape="RoundRectangle 8" HeightRequest="170" StrokeThickness="0" WidthRequest="45" VerticalOptions="End" />
                                        <Border Grid.Column="5" BackgroundColor="#624890" StrokeShape="RoundRectangle 8" HeightRequest="200" StrokeThickness="0" WidthRequest="45" VerticalOptions="End" />
                                    </Grid>
                                </Grid>
                                <!-- X-Axis -->
                                <Grid ColumnDefinitions="45,*,*,*,*,*,*" Padding="30,0,0,0">
                                    <Label Grid.Column="1" Text="Jan" FontSize="11" TextColor="#94A3B8" HorizontalOptions="Center" />
                                    <Label Grid.Column="2" Text="Feb" FontSize="11" TextColor="#94A3B8" HorizontalOptions="Center" />
                                    <Label Grid.Column="3" Text="Mar" FontSize="11" TextColor="#94A3B8" HorizontalOptions="Center" />
                                    <Label Grid.Column="4" Text="Apr" FontSize="11" TextColor="#94A3B8" HorizontalOptions="Center" />
                                    <Label Grid.Column="5" Text="May" FontSize="11" TextColor="#94A3B8" HorizontalOptions="Center" />
                                    <Label Grid.Column="6" Text="Jun" FontSize="11" TextColor="#94A3B8" HorizontalOptions="Center" />
                                </Grid>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Popular Products -->
                        <Border Grid.Column="1" BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="32" StrokeThickness="0">
                            <VerticalStackLayout Spacing="24">
                                <Label Text="Popular Products" FontSize="18" FontAttributes="Bold" TextColor="#463366" />
                                
                                <VerticalStackLayout Spacing="16">
                                    <!-- Product 1 -->
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                                        <Border BackgroundColor="#F3F0FA" StrokeShape="RoundRectangle 12" HeightRequest="56" WidthRequest="56" StrokeThickness="0">
                                            <Label Text="👗" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                            <Label Text="Silk Maxi Dress" FontAttributes="Bold" TextColor="#463366" FontSize="14" />
                                            <Label Text="124 sold • ₱2,490" FontSize="11" TextColor="#94A3B8" />
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End">
                                            <Label Text="45 left" FontAttributes="Bold" TextColor="#15803D" FontSize="12" />
                                            <Label Text="Stock" FontSize="10" TextColor="#94A3B8" HorizontalTextAlignment="End" />
                                        </VerticalStackLayout>
                                    </Grid>

                                    <!-- Product 2 -->
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                                        <Border BackgroundColor="#F3F0FA" StrokeShape="RoundRectangle 12" HeightRequest="56" WidthRequest="56" StrokeThickness="0">
                                            <Label Text="👕" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                            <Label Text="Cotton Linen Shirt" FontAttributes="Bold" TextColor="#463366" FontSize="14" />
                                            <Label Text="98 sold • ₱1,200" FontSize="11" TextColor="#94A3B8" />
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End">
                                            <Label Text="12 left" FontAttributes="Bold" TextColor="#B91C1C" FontSize="12" />
                                            <Label Text="Stock" FontSize="10" TextColor="#94A3B8" HorizontalTextAlignment="End" />
                                        </VerticalStackLayout>
                                    </Grid>

                                    <!-- Product 3 -->
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                                        <Border BackgroundColor="#F3F0FA" StrokeShape="RoundRectangle 12" HeightRequest="56" WidthRequest="56" StrokeThickness="0">
                                            <Label Text="👖" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                            <Label Text="High-Waist Trousers" FontAttributes="Bold" TextColor="#463366" FontSize="14" />
                                            <Label Text="85 sold • ₱1,850" FontSize="11" TextColor="#94A3B8" />
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End">
                                            <Label Text="67 left" FontAttributes="Bold" TextColor="#15803D" FontSize="12" />
                                            <Label Text="Stock" FontSize="10" TextColor="#94A3B8" HorizontalTextAlignment="End" />
                                        </VerticalStackLayout>
                                    </Grid>

                                    <!-- Product 4 -->
                                    <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="16">
                                        <Border BackgroundColor="#F3F0FA" StrokeShape="RoundRectangle 12" HeightRequest="56" WidthRequest="56" StrokeThickness="0">
                                            <Label Text="👚" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" />
                                        </Border>
                                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                                            <Label Text="Floral Summer Top" FontAttributes="Bold" TextColor="#463366" FontSize="14" />
                                            <Label Text="72 sold • ₱950" FontSize="11" TextColor="#94A3B8" />
                                        </VerticalStackLayout>
                                        <VerticalStackLayout Grid.Column="2" VerticalOptions="Center" HorizontalOptions="End">
                                            <Label Text="8 left" FontAttributes="Bold" TextColor="#B91C1C" FontSize="12" />
                                            <Label Text="Stock" FontSize="10" TextColor="#94A3B8" HorizontalTextAlignment="End" />
                                        </VerticalStackLayout>
                                    </Grid>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>
