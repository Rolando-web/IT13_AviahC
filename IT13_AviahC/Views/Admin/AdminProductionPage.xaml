<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:IT13_AviahC.Views.Admin.Components"
             xmlns:modals="clr-namespace:IT13_AviahC.Views.Modals"
             x:Class="IT13_AviahC.Views.Admin.AdminProductionPage"
             BackgroundColor="#F3F0FA">
    <Grid ColumnDefinitions="Auto,*">
        <!-- Reusable Sidebar -->
        <components:AdminSidebarView Grid.Column="0" CurrentPage="AdminProduction" />

        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <!-- Header -->
            <components:AdminHeaderView Grid.Row="0" />

            <ScrollView Grid.Row="1" Padding="32,24,32,32">
                    <VerticalStackLayout Spacing="32">
                        <!-- Header with Title & Action -->
                        <Grid ColumnDefinitions="*,Auto">
                            <VerticalStackLayout Spacing="8">
                                <Label Text="Production Output" FontSize="32" FontAttributes="Bold" TextColor="#463366" />
                                <Label Text="Active &amp; Recent Batches" FontSize="18" FontAttributes="Bold" TextColor="#7D6A9E" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1" Text="+ New Production Batch" Clicked="OnNewBatchClicked" BackgroundColor="#624890" TextColor="White" CornerRadius="12" FontAttributes="Bold" HeightRequest="48" Padding="24,0" VerticalOptions="Start" />
                        </Grid>
                        
                        <!-- Batches List (Full Width) -->
                        <CollectionView x:Name="ProductionCollection">
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="24" StrokeThickness="0" Margin="0,0,0,16">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="20">
                                            <!-- Status Icon Box -->
                                            <Border BackgroundColor="{Binding StatusBoxColor}" StrokeShape="RoundRectangle 16" HeightRequest="60" WidthRequest="60" StrokeThickness="0">
                                                <Label Text="{Binding StatusIcon}" FontSize="24" HorizontalOptions="Center" VerticalOptions="Center" TextColor="{Binding StatusIconColor}" />
                                            </Border>

                                            <!-- Center Info -->
                                            <VerticalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                                                <HorizontalStackLayout Spacing="10">
                                                    <Label Text="{Binding ProductName}" FontAttributes="Bold" FontSize="18" TextColor="#463366" />
                                                    <Border BackgroundColor="#F1F5F9" StrokeShape="RoundRectangle 6" Padding="8,2" StrokeThickness="0" VerticalOptions="Center">
                                                        <Label Text="{Binding BatchID}" FontSize="11" TextColor="#64748B" FontAttributes="Bold" />
                                                    </Border>
                                                </HorizontalStackLayout>
                                                
                                                <HorizontalStackLayout Spacing="8">
                                                    <Path Data="M11.99 2C6.47 2 2 6.48 2 12s4.47 10 9.99 10C17.52 22 22 17.52 22 12S17.52 2 11.99 2zM12 20c-4.42 0-8-3.58-8-8s3.58-8 8-8 8 3.58 8 8-3.58 8-8 8zm.5-13H11v6l5.25 3.15.75-1.23-4.5-2.67z" Fill="#94A3B8" HeightRequest="14" WidthRequest="14" VerticalOptions="Center" />
                                                    <Label Text="{Binding TimeStatus}" FontSize="13" TextColor="#94A3B8" VerticalOptions="Center" />
                                                </HorizontalStackLayout>

                                                <Label Text="{Binding TargetText}" FontSize="14" FontAttributes="Bold" TextColor="#624890" />
                                            </VerticalStackLayout>

                                            <!-- Right Progress & Action -->
                                            <VerticalStackLayout Grid.Column="2" Spacing="12" WidthRequest="220" VerticalOptions="Center">
                                                <Grid ColumnDefinitions="*,Auto">
                                                    <Label Text="Progress" FontSize="12" FontAttributes="Bold" TextColor="#64748B" />
                                                    <Label Grid.Column="1" Text="{Binding ProgressText}" FontSize="12" FontAttributes="Bold" TextColor="#463366" />
                                                </Grid>
                                                
                                                <Border BackgroundColor="#F1F5F9" StrokeShape="RoundRectangle 6" HeightRequest="8" StrokeThickness="0">
                                                    <BoxView BackgroundColor="{Binding ProgressColor}" HeightRequest="8" WidthRequest="{Binding ProgressWidth}" HorizontalOptions="Start" />
                                                </Border>

                                                <Button Text="{Binding ActionButtonText}" Clicked="OnUpdateBatchClicked" CommandParameter="{Binding .}" 
                                                        BackgroundColor="Transparent" BorderColor="#624890" BorderWidth="1" TextColor="#624890" CornerRadius="12" HeightRequest="36" Padding="16,0" FontSize="12" FontAttributes="Bold" />
                                            </VerticalStackLayout>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>

                    <!-- Bottom: Finished Goods Catalog -->
                    <VerticalStackLayout Spacing="16" Margin="0,16,0,0">
                        <Label Text="Finished Goods Catalog" FontSize="20" FontAttributes="Bold" TextColor="#463366" />
                        <CollectionView x:Name="FinishedProductsCollection">
                            <CollectionView.ItemsLayout>
                                <GridItemsLayout Orientation="Vertical" Span="4" HorizontalItemSpacing="24" VerticalItemSpacing="24" />
                            </CollectionView.ItemsLayout>
                            <CollectionView.ItemTemplate>
                                <DataTemplate>
                                    <Border BackgroundColor="White" StrokeShape="RoundRectangle 2" Padding="0" StrokeThickness="1" Stroke="#E2E8F0" Margin="5">
                                        <VerticalStackLayout Spacing="0">
                                            <Image Source="{Binding ImageUrl}" Aspect="AspectFill" HeightRequest="300" />
                                            <VerticalStackLayout Padding="15" Spacing="10">
                                                <Label Text="{Binding ProductName}" FontAttributes="Bold" FontSize="16" TextColor="#1E293B" />
                                                
                                                <VerticalStackLayout Spacing="4">
                                                    <Label Text="Material:" FontSize="14" FontAttributes="Bold" TextColor="#1E293B" />
                                                    <Label Text="{Binding Material1}" FontSize="13" TextColor="#64748B" />
                                                    <Label Text="Material:" FontSize="14" FontAttributes="Bold" TextColor="#1E293B" />
                                                    <Label Text="{Binding Material2}" FontSize="13" TextColor="#64748B" />
                                                </VerticalStackLayout>

                                                <Button Text="Make" Clicked="OnMakeProductClicked" CommandParameter="{Binding .}" BackgroundColor="#624890" TextColor="White" CornerRadius="15" FontAttributes="Bold" HeightRequest="35" Margin="0,10,0,0" />
                                            </VerticalStackLayout>
                                        </VerticalStackLayout>
                                    </Border>
                                </DataTemplate>
                            </CollectionView.ItemTemplate>
                        </CollectionView>
                        </VerticalStackLayout>
                        
                        <!-- Make Progress Section -->
                        <VerticalStackLayout Spacing="16" Margin="0,16,0,0">
                            <VerticalStackLayout Spacing="4">
                                <Label Text="Make Progress" FontSize="20" FontAttributes="Bold" TextColor="#463366" />
                                <Label x:Name="ActiveProductsSummaryLabel" Text="Currently Producing: Calculating..." FontSize="14" TextColor="#64748B" FontAttributes="Italic" />
                            </VerticalStackLayout>
                            
                            <Grid ColumnDefinitions="*,*,*" ColumnSpacing="24">
                                <!-- Goal 1 -->
                                <Border BackgroundColor="White" StrokeShape="RoundRectangle 16" Padding="20" StrokeThickness="0">
                                    <VerticalStackLayout Spacing="12">
                                        <Label Text="Weekly Production Quota" FontSize="14" FontAttributes="Bold" TextColor="#64748B" />
                                        <Label x:Name="WeeklyGoalLabel" Text="0 / 0 pcs" FontSize="24" FontAttributes="Bold" TextColor="#463366" />
                                        <Border BackgroundColor="#F1F5F9" StrokeShape="RoundRectangle 6" HeightRequest="8" StrokeThickness="0">
                                            <!-- Responsive width via Grid or binding if needed, hardcoded visual for now -->
                                            <BoxView x:Name="WeeklyGoalBar" BackgroundColor="#22C55E" HeightRequest="8" WidthRequest="0" HorizontalOptions="Start" />
                                        </Border>
                                        <Label x:Name="WeeklyGoalPercentLabel" Text="0% Completed" FontSize="12" FontAttributes="Bold" TextColor="#22C55E" />
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Goal 2 -->
                                <Border Grid.Column="1" BackgroundColor="White" StrokeShape="RoundRectangle 16" Padding="20" StrokeThickness="0">
                                    <VerticalStackLayout Spacing="12">
                                        <Label Text="Quality Control Pass Rate" FontSize="14" FontAttributes="Bold" TextColor="#64748B" />
                                        <Label x:Name="QcPassRateLabel" Text="0%" FontSize="24" FontAttributes="Bold" TextColor="#463366" />
                                        <Border BackgroundColor="#F1F5F9" StrokeShape="RoundRectangle 6" HeightRequest="8" StrokeThickness="0">
                                            <BoxView x:Name="QcPassRateBar" BackgroundColor="#624890" HeightRequest="8" WidthRequest="0" HorizontalOptions="Start" />
                                        </Border>
                                        <Label x:Name="QcStatusLabel" Text="Evaluating" FontSize="12" FontAttributes="Bold" TextColor="#624890" />
                                    </VerticalStackLayout>
                                </Border>

                                <!-- Goal 3 -->
                                <Border Grid.Column="2" BackgroundColor="White" StrokeShape="RoundRectangle 16" Padding="20" StrokeThickness="0">
                                    <VerticalStackLayout Spacing="12">
                                        <Label Text="Material Utilization" FontSize="14" FontAttributes="Bold" TextColor="#64748B" />
                                        <Label x:Name="MaterialUtilLabel" Text="0% Efficiency" FontSize="24" FontAttributes="Bold" TextColor="#463366" />
                                        <Border BackgroundColor="#F1F5F9" StrokeShape="RoundRectangle 6" HeightRequest="8" StrokeThickness="0">
                                            <BoxView x:Name="MaterialUtilBar" BackgroundColor="#F59E0B" HeightRequest="8" WidthRequest="0" HorizontalOptions="Start" />
                                        </Border>
                                        <Label x:Name="MaterialStatusLabel" Text="Evaluating" FontSize="12" FontAttributes="Bold" TextColor="#F59E0B" />
                                    </VerticalStackLayout>
                                </Border>
                            </Grid>
                        </VerticalStackLayout>
                    </VerticalStackLayout>
                </ScrollView>
        </Grid>
        <modals:StartProductionModal x:Name="ProductionModalView" Grid.ColumnSpan="2" IsVisible="False" />
    </Grid>
</ContentPage>
