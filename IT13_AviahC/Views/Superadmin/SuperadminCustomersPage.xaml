                                        <Label Text="Premium" FontSize="10" TextColor="#624890" FontAttributes="Bold" />
                                    </Border>
                                    <Label Grid.Row="3" Grid.Column="3" Text="8 users" FontSize="13" TextColor="#64748B" HorizontalTextAlignment="Center" VerticalOptions="Center" />
                                    <Label Grid.Row="3" Grid.Column="4" Text="₱2,000" FontSize="13" FontAttributes="Bold" TextColor="#1E293B" VerticalOptions="Center" />
                                    <HorizontalStackLayout Grid.Row="3" Grid.Column="5" Spacing="16" VerticalOptions="Center" Margin="0,0,24,0">
                                        <Label Text="Jun 01" FontSize="12" TextColor="#64748B" />
