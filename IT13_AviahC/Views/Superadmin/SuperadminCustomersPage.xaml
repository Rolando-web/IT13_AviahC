                                    <Label Grid.Row="2" Grid.Column="4" Text="₱1,200" FontSize="13" FontAttributes="Bold" TextColor="#1E293B" VerticalOptions="Center" />
                                    <HorizontalStackLayout Grid.Row="2" Grid.Column="5" Spacing="16" VerticalOptions="Center" Margin="0,0,24,0">
