                                </VerticalStackLayout>
                            </Border>

                            <Border BackgroundColor="#EFF6FF" StrokeShape="RoundRectangle 16" Padding="24" StrokeThickness="0">
                                <VerticalStackLayout Spacing="12">
                                    <HorizontalStackLayout Spacing="12">
                                        <Border BackgroundColor="#2563EB" StrokeShape="RoundRectangle 4" Padding="8,2" StrokeThickness="0">
                                            <Label Text="TIER 2" TextColor="White" FontSize="10" FontAttributes="Bold" />
