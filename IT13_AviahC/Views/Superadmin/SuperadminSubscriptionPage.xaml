                                    <Label Text="Purpose: To support growing MSMEs with more advanced operations, including production and supplier management, while providing basic reporting." FontSize="14" TextColor="#64748B" />
                                </VerticalStackLayout>
                            </Border>

                            <Border BackgroundColor="#F3F0FA" StrokeShape="RoundRectangle 16" Padding="24" StrokeThickness="3" Stroke="#624890">
                                <VerticalStackLayout Spacing="12">
                                    <HorizontalStackLayout Spacing="12">
                                        <Border BackgroundColor="#624890" StrokeShape="RoundRectangle 4" Padding="8,2" StrokeThickness="0">
                                            <Label Text="TIER 3" TextColor="White" FontSize="10" FontAttributes="Bold" />
