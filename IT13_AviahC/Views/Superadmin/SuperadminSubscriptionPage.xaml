                                                <Label Text="Customer Portal Integration" FontSize="13" TextColor="#64748B" />
                                            </HorizontalStackLayout>
                                            <HorizontalStackLayout Spacing="12">
                                                <Path Data="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z" Fill="#624890" HeightRequest="16" WidthRequest="16" VerticalOptions="Center" />
                                                <Label Text="CRM Promotions &amp; Discounts" FontSize="13" TextColor="#64748B" />
