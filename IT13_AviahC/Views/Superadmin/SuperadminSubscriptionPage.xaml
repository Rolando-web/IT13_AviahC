                                        <Label Text="Accessible Pages / Services:" FontAttributes="Bold" FontSize="13" TextColor="#1E293B" Margin="0,8,0,0" />
                                        
                                        <VerticalStackLayout Spacing="12">
                                            <HorizontalStackLayout Spacing="12">
                                                <Ellipse WidthRequest="16" HeightRequest="16" Stroke="#94A3B8" StrokeThickness="1.5" VerticalOptions="Center">
