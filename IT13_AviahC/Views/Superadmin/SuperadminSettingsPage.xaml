<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:components="clr-namespace:IT13_AviahC.Views.Components"
             xmlns:scomp="clr-namespace:IT13_AviahC.Views.Superadmin.Components"
             x:Class="IT13_AviahC.Views.Superadmin.SuperadminSettingsPage"
             BackgroundColor="#F3F0FA">
    <Grid ColumnDefinitions="Auto,*">
        <!-- Shared Sidebar -->
        <components:SidebarView Grid.Column="0" CurrentPage="SuperadminSettings" ModuleTitle="SUPER ADMIN MODULES" />

        <Grid Grid.Column="1" RowDefinitions="Auto,*">
            <!-- Header -->
            <scomp:SuperadminHeaderView Grid.Row="0" />

            <ScrollView Grid.Row="1">
                <VerticalStackLayout Padding="32" Spacing="24">
                    <!-- Title Section -->
                    <Grid ColumnDefinitions="*,Auto">
                        <VerticalStackLayout Spacing="4">
                            <Label Text="Global System Settings" FontSize="24" FontAttributes="Bold" TextColor="#463366" />
                            <Label Text="Configure global system behavior, security, and tenant defaults" FontSize="14" TextColor="#7D6A9E" />
                        </VerticalStackLayout>
                        <HorizontalStackLayout Grid.Column="1" Spacing="12" VerticalOptions="Center">
                            <Button Text="Reset Defaults" BackgroundColor="Transparent" BorderColor="#624890" BorderWidth="1" TextColor="#624890" CornerRadius="12" FontAttributes="Bold" HeightRequest="44" Padding="20,0" />
                            <Button Text="Save All Changes" BackgroundColor="#624890" TextColor="White" CornerRadius="12" FontAttributes="Bold" HeightRequest="44" Padding="24,0" />
                        </HorizontalStackLayout>
                    </Grid>

                    <Grid ColumnDefinitions="*,*" ColumnSpacing="24">
                        <!-- Left: Core App Config -->
                        <Border BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="32" StrokeThickness="0">
                            <VerticalStackLayout Spacing="32">
                                <HorizontalStackLayout Spacing="16">
                                    <Border BackgroundColor="#F3F0FA" StrokeShape="RoundRectangle 12" HeightRequest="48" WidthRequest="48" StrokeThickness="0">
                                        <Path Data="M19.14 12.94c.04-.3.06-.61.06-.94 0-.32-.02-.64-.07-.94l2.03-1.58c.18-.14.23-.41.12-.61l-1.92-3.32c-.12-.22-.37-.29-.59-.22l-2.39.96c-.5-.38-1.03-.7-1.62-.94l-.36-2.54c-.04-.24-.24-.41-.48-.41h-3.84c-.24 0-.43.17-.47.41l-.36 2.54c-.59.24-1.13.57-1.62.94l-2.39-.96c-.22-.08-.47 0-.59.22L2.74 8.87c-.12.21-.08.47.12.61l2.03 1.58c-.05.3-.09.63-.09.94s.02.64.07.94l-2.03 1.58c-.18.14-.23.41-.12.61l1.92 3.32c.12.22.37.29.59.22l2.39-.96c.5.38 1.03.7 1.62.94l.36 2.54c.05.24.24.41.48.41h3.84c.24 0 .44-.17.47-.41l.36-2.54c.59-.24 1.13-.56 1.62-.94l2.39.96c.22.08.47 0 .59-.22l1.92-3.32c.12-.21.07-.47-.12-.61l-2.01-1.58zM12 15.6c-1.98 0-3.6-1.62-3.6-3.6s1.62-3.6 3.6-3.6 3.6 1.62 3.6 3.6-1.62 3.6-3.6 3.6z"
                                              Fill="#624890" Aspect="Uniform" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Label Text="System Configuration" FontAttributes="Bold" FontSize="18" TextColor="#463366" VerticalOptions="Center" />
                                </HorizontalStackLayout>

                                <VerticalStackLayout Spacing="24">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="Global System Display Name" FontSize="13" FontAttributes="Bold" TextColor="#463366" />
                                        <Border BackgroundColor="#F8FAFC" StrokeShape="RoundRectangle 16" Padding="16,4" StrokeThickness="0">
                                            <Entry Text="Aviah Collection ERP/CRM" TextColor="#1E293B" FontSize="15" HeightRequest="48" BackgroundColor="Transparent" />
                                        </Border>
                                    </VerticalStackLayout>

                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Spacing="4">
                                            <Label Text="Multi-Tenant Isolation" FontAttributes="Bold" FontSize="15" TextColor="#463366" />
                                            <Label Text="Ensure strict data separation between enterprise tenants." FontSize="12" TextColor="#7D6A9E" />
                                        </VerticalStackLayout>
                                        <Switch Grid.Column="1" IsToggled="True" ThumbColor="White" OnColor="#624890" VerticalOptions="Center" />
                                    </Grid>

                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Spacing="4">
                                            <Label Text="Maintenance Mode" FontAttributes="Bold" FontSize="15" TextColor="#463366" />
                                            <Label Text="Redirect all traffic to maintenance landing page." FontSize="12" TextColor="#7D6A9E" />
                                        </VerticalStackLayout>
                                        <Switch Grid.Column="1" IsToggled="False" ThumbColor="White" OnColor="#624890" VerticalOptions="Center" />
                                    </Grid>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>

                        <!-- Right: Security Config -->
                        <Border Grid.Column="1" BackgroundColor="White" StrokeShape="RoundRectangle 24" Padding="32" StrokeThickness="0">
                            <VerticalStackLayout Spacing="32">
                                <HorizontalStackLayout Spacing="16">
                                    <Border BackgroundColor="#F3F0FA" StrokeShape="RoundRectangle 12" HeightRequest="48" WidthRequest="48" StrokeThickness="0">
                                        <Path Data="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-1 6h2v2h-2V7zm0 4h2v6h-2v-6z"
                                              Fill="#624890" Aspect="Uniform" HeightRequest="20" WidthRequest="20" HorizontalOptions="Center" VerticalOptions="Center" />
                                    </Border>
                                    <Label Text="Security &amp; Auth" FontAttributes="Bold" FontSize="18" TextColor="#463366" VerticalOptions="Center" />
                                </HorizontalStackLayout>

                                <VerticalStackLayout Spacing="24">
                                    <VerticalStackLayout Spacing="8">
                                        <Label Text="Session Timeout (Minutes)" FontSize="13" FontAttributes="Bold" TextColor="#463366" />
                                        <Border BackgroundColor="#F8FAFC" StrokeShape="RoundRectangle 16" Padding="16,4" StrokeThickness="0">
                                            <Entry Text="60" Keyboard="Numeric" TextColor="#1E293B" FontSize="15" HeightRequest="48" BackgroundColor="Transparent" />
                                        </Border>
                                    </VerticalStackLayout>

                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Spacing="4">
                                            <Label Text="Enforce 2FA" FontAttributes="Bold" FontSize="15" TextColor="#463366" />
                                            <Label Text="Require all admins to use two-factor auth." FontSize="12" TextColor="#7D6A9E" />
                                        </VerticalStackLayout>
                                        <Switch Grid.Column="1" IsToggled="True" ThumbColor="White" OnColor="#624890" VerticalOptions="Center" />
                                    </Grid>

                                    <Grid ColumnDefinitions="*,Auto">
                                        <VerticalStackLayout Spacing="4">
                                            <Label Text="IP Access Control List" FontAttributes="Bold" FontSize="15" TextColor="#463366" />
                                            <Label Text="Restrict access to authorized office IPs only." FontSize="12" TextColor="#7D6A9E" />
                                        </VerticalStackLayout>
                                        <Switch Grid.Column="1" IsToggled="True" ThumbColor="White" OnColor="#624890" VerticalOptions="Center" />
                                    </Grid>
                                </VerticalStackLayout>
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>
            </ScrollView>
        </Grid>
    </Grid>
</ContentPage>
